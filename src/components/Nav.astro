---
const navLinks = [
  { href: '/about/', label: 'About' },
  { href: '/engagements/', label: 'Engagements' },
  { href: '/services/', label: 'Services' },
  { href: '/praxis/', label: 'Praxis' },
  { href: '/contact/', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<div id="nav-sentinel" aria-hidden="true" style="position:absolute;top:0;left:0;width:1px;height:1px;"></div>

<header id="site-nav" role="banner">
  <nav class="nav-inner container" aria-label="Main navigation">
    <a href="/" class="nav-wordmark" aria-label="Sarif Consulting — Home">
      SARIF CONSULTING
    </a>

    <ul class="nav-links" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { 'nav-link--active': currentPath === link.href || currentPath.startsWith(link.href + '/') }]}
            data-materialize-text="pending"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="nav-trailing">
      <button
        id="nav-toggle"
        class="nav-toggle"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </nav>

  <div id="nav-mobile" class="nav-mobile" role="dialog" aria-modal="true" aria-label="Navigation menu" hidden>
    <button
      id="nav-close"
      class="nav-close"
      aria-label="Close navigation menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <line x1="4" y1="4" x2="20" y2="20" stroke="var(--cyan-core)" stroke-width="1.5" stroke-linecap="square"/>
        <line x1="20" y1="4" x2="4" y2="20" stroke="var(--cyan-core)" stroke-width="1.5" stroke-linecap="square"/>
      </svg>
    </button>
    <ul class="nav-mobile-links" role="list">
      {navLinks.map((link, i) => (
        <li style={`--delay: ${i * 100}ms`}>
          <a
            href={link.href}
            class:list={[
              'nav-mobile-link',
              {
                'nav-mobile-link--active':
                  currentPath === link.href || currentPath.startsWith(link.href + '/'),
              },
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<style>
  #site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding-top: env(safe-area-inset-top, 0px);
    background: transparent;
    transition: background 0.3s ease, backdrop-filter 0.3s ease, box-shadow 0.3s ease;
    will-change: background;
  }

  #site-nav.scrolled {
    background: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    border-bottom: 1px solid rgba(0, 212, 255, 0.12);
    box-shadow:
      0 4px 30px rgba(0, 0, 0, 0.08),
      0 1px 0 rgba(255, 255, 255, 0.3);
  }

  #site-nav::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--cyan-core), transparent);
    transition: width 0.6s ease;
    pointer-events: none;
  }

  #site-nav.scrolled::after {
    width: 100%;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  /* Warm gold on dark / transparent bar */
  .nav-wordmark {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    background: linear-gradient(
      180deg,
      var(--gold-deep) 0%,
      var(--sarif-gold) 38%,
      var(--gold-bright) 50%,
      var(--sarif-gold) 62%,
      var(--gold-deep) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    flex-shrink: 0;
    transition: filter 0.25s ease, opacity 0.25s ease;
    filter: drop-shadow(0 0 10px rgba(201, 162, 39, 0.2));
  }

  .nav-wordmark:hover,
  .nav-wordmark:focus-visible {
    opacity: 1;
    filter: drop-shadow(0 0 16px rgba(221, 184, 61, 0.45));
    outline: none;
  }

  /*
   * Frosted bar: bright gold gradient clip-text reads as low-contrast yellow on light glass.
   * Solid deep bronze + subtle light rim keeps the warm brand read without washing out.
   */
  #site-nav.scrolled .nav-wordmark {
    background: none;
    -webkit-background-clip: unset;
    background-clip: unset;
    -webkit-text-fill-color: #3f3108;
    color: #3f3108;
    filter: none;
    text-shadow:
      0 1px 0 rgba(255, 255, 255, 0.88),
      0 0 12px rgba(255, 255, 255, 0.45);
  }

  #site-nav.scrolled .nav-wordmark:hover,
  #site-nav.scrolled .nav-wordmark:focus-visible {
    color: #5a4610;
    -webkit-text-fill-color: #5a4610;
    text-shadow:
      0 1px 0 rgba(255, 255, 255, 0.92),
      0 0 10px rgba(255, 255, 255, 0.5);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 36px;
    list-style: none;
  }

  .nav-link {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-secondary);
    position: relative;
    padding-bottom: 4px;
    transition: color 0.2s ease;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--cyan-core);
    transition: width 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .nav-link:hover {
    color: var(--cyan-core);
  }

  .nav-link:hover::after,
  .nav-link--active::after {
    width: 100%;
  }

  .nav-link--active {
    color: var(--cyan-core);
  }

  /* Pillar 6c — cross-document View Transitions API hookup.
     Tagging the active nav link with a stable `view-transition-name`
     allows the browser to morph the cyan underline between routes
     instead of cross-fading the two nav states. Only one node in the
     document can hold any given name at a time; because exactly one
     `.nav-link--active` is rendered per page, that invariant holds.
     The `::after` pseudo carries the visible underline, so we tag it
     in addition to the anchor — the underline becomes the morph target.
     Reduced-motion users opt out entirely: the browser falls back to
     the default opacity crossfade, which is our existing behaviour. */
  @supports (view-transition-name: none) {
    @media (prefers-reduced-motion: no-preference) {
      .nav-link--active {
        view-transition-name: nav-active-link;
      }
      .nav-link--active::after {
        view-transition-name: nav-active-underline;
      }
    }
  }

  .nav-trailing {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: 12px;
    /* WCAG 2.5.5 AAA: 44x44 target. Hamburger bars are 22x1.5x3
       (≈14.5px tall), so 12px y-padding yields ~38.5px — below the
       AAA floor. The 15px block padding below bumps the hit zone
       to 44.5px without shifting the bars' optical centre. */
  }

  @media (pointer: coarse) {
    .nav-toggle {
      padding-block: 15px;
      padding-inline: 11px;
    }
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--chrome-dark);
    transform-origin: left center;
    transition: var(--transition-hover);
  }

  .hamburger-line:nth-child(1) { transform: rotate(-2deg); }
  .hamburger-line:nth-child(3) { transform: rotate(2deg); }

  .nav-toggle[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: rotate(0deg);
  }
  .nav-toggle[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: rotate(0deg);
  }

  .nav-mobile {
    position: fixed;
    inset: 0;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(30px) saturate(1.3);
    -webkit-backdrop-filter: blur(30px) saturate(1.3);
    z-index: 999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .nav-mobile:not([hidden]) {
    opacity: 1;
    visibility: visible;
  }

  .nav-mobile[hidden] {
    display: flex !important;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .nav-close {
    position: absolute;
    top: 24px;
    right: 24px;
    background: none;
    border: none;
    padding: 12px;
    /* SVG is 24x24, padding 12px → 48x48 tap target. Already AAA. */
    min-width: 48px;
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .nav-mobile-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .nav-mobile-links li {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.4s ease var(--delay), transform 0.4s ease var(--delay);
  }

  .nav-mobile:not([hidden]) .nav-mobile-links li {
    opacity: 1;
    transform: translateY(0);
  }

  .nav-mobile-link {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--chrome-dark);
    transition: color 0.2s ease;
    /* Generous padded hit area on the anchor itself so finger taps
       have AAA breathing room even between the 40px gap rows. The
       inline padding also reduces mis-taps on the leftmost character
       (closest to the viewport edge). */
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 8px 16px;
  }

  .nav-mobile-link:hover,
  .nav-mobile-link--active {
    color: var(--cyan-core);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .nav-toggle {
      display: flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-mobile,
    .nav-mobile-links li {
      transition: none;
    }
    #site-nav::after {
      transition: none;
    }
  }
</style>

<script src="../scripts/nav.js"></script>
