---
/**
 * MDX Sidenote — marginalia on desktop, inline aside on mobile.
 *
 * Usage:
 *   Body copy with a thought <Sidenote>that is tangential to the main thread.</Sidenote>
 *
 * Implementation:
 * - Uses CSS grid with a right-margin lane on wide viewports.
 * - On narrow viewports it collapses inline; the content is preserved
 *   regardless so screen readers get a consistent story.
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<aside class:list={['mdx-sidenote', className]} role="note">
  <slot />
</aside>

<style>
  .mdx-sidenote {
    display: block;
    font-family: var(--font-body);
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text-secondary);
    border-left: 1px solid rgba(0, 212, 255, 0.3);
    padding: 8px 0 8px 14px;
    margin: 16px 0;
  }

  @media (min-width: 1100px) {
    .mdx-sidenote {
      float: right;
      clear: right;
      width: 220px;
      margin: 4px -240px 12px 20px;
      font-size: 0.82rem;
      border-left: none;
      padding-left: 0;
      border-top: 1px solid rgba(0, 212, 255, 0.3);
      padding-top: 8px;
    }
  }
</style>
