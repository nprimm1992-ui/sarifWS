---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import PraxisAsk from '../components/PraxisAsk.astro';

/**
 * Corpus-size gate for the Praxis field-notes assistant (PraxisAsk).
 *
 * The assistant runs a lexical token-intersection search over the
 * published Praxis corpus (see src/scripts/praxis-ask.js). Below a
 * meaningful corpus size, every multi-token query either matches the
 * entire library or nothing — the UX reads as a toy even though the
 * pipeline is production-grade. Gate the *surface* on corpus depth
 * while leaving the backend warm:
 *
 *   - /search-index.json still emits all Praxis entries (also powers
 *     the command palette; must not be gated).
 *   - /api/ask Cloudflare Function stays deployed; writes simply
 *     pause while the UI is absent.
 *   - Component source + CSS stay in the tree so re-enable is zero-
 *     effort: ship the 12th article and the next build restores it.
 *
 * Threshold rationale: 12 is roughly a year of monthly cadence, which
 * gives the scoring weights (title 3× / tags 2× / summary 1×) enough
 * lexical spread to actually discriminate between articles rather
 * than returning the same 2–3 results for every query.
 */
const PRAXIS_ASK_MIN_CORPUS = 12;

const published = (await getCollection('praxis', (entry) => !entry.data.draft)).sort(
  (a, b) => a.data.publishDate.getTime() - b.data.publishDate.getTime(),
);

const praxisAskEnabled = published.length >= PRAXIS_ASK_MIN_CORPUS;

// Faceted navigation (P9c) — distinct values for sidebar filters. URL state
// lives in query params; the client script toggles DOM visibility on
// popstate so SSR continues to render all articles (no-JS path works).
const facetSets = {
  lens: new Set<string>(),
  tags: new Set<string>(),
};
for (const entry of published) {
  facetSets.lens.add(entry.data.lens);
  for (const tag of entry.data.tags ?? []) facetSets.tags.add(tag);
}
const facets = {
  lens: [...facetSets.lens].sort(),
  tags: [...facetSets.tags].sort(),
};

const praxisPublishedLabel = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' });
---

<Base
  title="Praxis — Sarif Consulting"
  description="Practice made public. Monthly intelligence-architecture, ethics and systems-design writing drawn from live operational work — not polished after-the-fact deliverables."
>
  {/*
    Unified Praxis surface — hero + filter grid + list live in a single
    CSS grid so the eyebrow, H1, lede, and tag chips share a scaffold
    with the facets sidebar, the Ask widget, the card list, and the
    empty-state container. Two layout variants are driven by data-state
    on the inner container:
      data-state="index"  — full grid (hero hero / facets ask / facets list / facets empty)
      data-state="coming" — single-column flex (hero + wireframe preview)

    Praxis numbering convention (locked — see Lexicon #praxis):
    Every published piece carries a sequential identifier in the form
    "Praxis No. 0N" as its primary header. The archive reads as one
    ongoing series, not a dated feed. Category tag and date are
    secondary metadata; the number is the identity. Never add a suffix
    to the section name itself ("Praxis Reports", "Praxis Feed", etc.).
  */}
  <section class="praxis section" aria-labelledby="praxis-heading">
    <div
      class="container praxis__inner"
      data-state={published.length > 0 ? 'index' : 'coming'}
    >
      <header class="praxis__hero">
        <p class="section-label reveal-on-scroll">Learn more</p>
        <h1 id="praxis-heading" class="section-header connector-line reveal-on-scroll">Praxis</h1>

        <div class="praxis-coming content-back-panel reveal-on-scroll">
          <h2 id="coming-heading" class="coming-title sarif-gold-cap-line">
            Practice made public. Intelligence architecture, ethics, systems design.
          </h2>
          <p class="coming-body">
            Praxis is the Sarif publication where operational thinking, methodology in progress and architectural observations are published as they are developed — not retrofitted into polished deliverables. Each piece is an operational position that has already been tested against real engagements before it is written up. Expect a single considered release per month, not a feed.
          </p>
        </div>
      </header>

      {published.length === 0 && (
        <div class="praxis-preview reveal-on-scroll cv-auto" data-cv-size="md" aria-hidden="true" data-lobby-subpose="praxis-proof">
          <div class="preview-entry">
            <div class="preview-meta-row">
              <span class="preview-num">Praxis No. 01</span>
              <span class="preview-date">2026.04.XX</span>
            </div>
            <span class="preview-tag">Methodology</span>
            <div class="preview-title-placeholder"></div>
            <div class="preview-excerpt-placeholder"></div>
            <div class="preview-excerpt-placeholder preview-excerpt--short"></div>
          </div>
          <div class="preview-entry">
            <div class="preview-meta-row">
              <span class="preview-num">Praxis No. 02</span>
              <span class="preview-date">2026.05.XX</span>
            </div>
            <span class="preview-tag">Systems</span>
            <div class="preview-title-placeholder"></div>
            <div class="preview-excerpt-placeholder"></div>
            <div class="preview-excerpt-placeholder preview-excerpt--short"></div>
          </div>
          <div class="preview-entry">
            <div class="preview-meta-row">
              <span class="preview-num">Praxis No. 03</span>
              <span class="preview-date">2026.06.XX</span>
            </div>
            <span class="preview-tag">Field Observation</span>
            <div class="preview-title-placeholder"></div>
            <div class="preview-excerpt-placeholder"></div>
            <div class="preview-excerpt-placeholder preview-excerpt--short"></div>
          </div>
        </div>
      )}

      {published.length > 0 && (
        <>
          <aside
            class="praxis__facets panel-frost-base panel-dossier panel-dossier--interactive"
            aria-label="Filter Praxis articles"
            data-praxis-facets
          >
            {/*
              Horizontal accent rail — flipped version of the About
              dossier card's vertical left rail. The `practice` accent
              gradient (cyan → cyan 0.45 → gold 0.55) runs left→right;
              the parent's `clip-path: var(--clip-card)` chamfer
              naturally truncates the strip at the octagonal corners
              so it matches the surrounding dossier grammar. The strip
              sits above the frost layer (z-index 2) and below the
              pill row (pills are in normal flow; their stacking
              context is higher by default).
            */}
            <div class="praxis__facets-accent" aria-hidden="true"></div>
            <p class="praxis__facets-heading ui-eyebrow">Filter</p>
            {(['lens', 'tags'] as const).map((group) => (
              <div class="praxis__facet-group" data-facet-group={group}>
                <p class="praxis__facet-label ui-eyebrow">{group}</p>
                <ul class="praxis__facet-list" role="list">
                  {facets[group].map((value) => (
                    <li>
                      <button
                        type="button"
                        class="praxis__facet-btn"
                        data-facet={group}
                        data-facet-value={value}
                        aria-pressed="false"
                      >
                        {value}
                      </button>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
            <button
              type="button"
              class="praxis__facet-clear"
              data-facet-clear
              aria-label="Clear all Praxis filters"
            >
              Clear filters
            </button>
          </aside>

          {praxisAskEnabled && <PraxisAsk />}

          {/*
            Subpose stays on the list — when the reader scrolls past
            the hero into the proof area, the camera drifts to the
            praxis-proof delta (warmth + slight dolly). Attaching it
            to the section would flip the subpose on at the top of
            the page and change established camera behavior.
          */}
          <div class="praxis__list" role="list" data-praxis-list data-lobby-subpose="praxis-proof">
            {published.map((entry, idx) => {
              const num = String(idx + 1).padStart(2, '0');
              const vtHero = `praxis-hero-${entry.id}`;
              const vtTitle = `praxis-title-${entry.id}`;
              return (
                <article
                  class="praxis-card panel-dossier panel-dossier--interactive"
                  role="listitem"
                  data-praxis-card
                  data-lens={entry.data.lens}
                  data-tags={entry.data.tags.join('|')}
                >
                  <div class="praxis-card__accent" aria-hidden="true"></div>
                  <div class="praxis-card__light" aria-hidden="true"></div>
                  <span class="praxis-card__num-watermark" aria-hidden="true">{num}</span>
                  <a href={`/praxis/${entry.id}/`} class="praxis-card__link">
                    <div class="praxis-card__meta-row">
                      <span class="praxis-card__num">Praxis No. {num}</span>
                      <span class="praxis-card__date">
                        <time datetime={entry.data.publishDate.toISOString()}>
                          {praxisPublishedLabel(entry.data.publishDate)}
                        </time>
                      </span>
                    </div>
                    <span class="praxis-card__lens">{entry.data.lens}</span>
                    <h3
                      class="praxis-card__title"
                      style={`--vt-title: ${vtTitle};`}
                    >
                      {entry.data.title}
                    </h3>
                    <p class="praxis-card__summary">{entry.data.summary}</p>
                    <span
                      class="praxis-card__vt-hero"
                      style={`--vt-hero: ${vtHero};`}
                      aria-hidden="true"
                    ></span>
                  </a>
                </article>
              );
            })}
          </div>

          <div
            class="praxis__empty"
            id="praxis-empty-state"
            data-praxis-empty
            role="status"
            aria-live="polite"
            tabindex="-1"
            hidden
          >
            <p class="praxis__empty-copy">
              No Praxis articles match those filters.
              <button type="button" class="praxis__empty-clear" data-facet-clear>
                Clear filters
              </button>
              to see everything.
            </p>
          </div>
        </>
      )}
    </div>
  </section>
</Base>

<style>
  /* Round-8 — unified Praxis grid.
     One <section> hosts the hero, the facets aside, PraxisAsk, the
     card list, and the empty-state in a single scaffold. Two layout
     variants are driven by [data-state] on `.praxis__inner`:
       data-state="index"  — full grid: hero spans both columns,
                             facets sticks beside ask/list/empty.
       data-state="coming" — centered stack: hero + wireframe preview.
     Removing the old `.praxis-hero` + `.praxis-index` section split
     lets the grid's row gap handle inter-block rhythm, so the stale
     `.praxis-coming { margin-bottom: 80px }` and
     `.praxis-index { padding-top: 48px }` are both dropped. */
  /* Praxis is a single-column stack: hero → facets → list → empty.
     The filter aside lives in normal document flow as its own grid
     row above the list; it scrolls with the page like any other
     block. No fixed/sticky positioning.

     The `ask` row is only allocated when PraxisAsk renders — the
     component is corpus-size gated (see PRAXIS_ASK_MIN_CORPUS in
     the frontmatter), so below the threshold we must not leave an
     empty grid row that inherits the row `gap` and produces a
     phantom vertical band. `:has()` keeps the two templates in
     lockstep with the render gate with zero extra props. */
  .praxis__inner[data-state='index'] {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-template-areas:
      'hero'
      'facets'
      'list'
      'empty';
    gap: clamp(28px, 5vw, 56px);
    align-items: start;
  }

  .praxis__inner[data-state='index']:has(.praxis-ask) {
    grid-template-areas:
      'hero'
      'facets'
      'ask'
      'list'
      'empty';
  }

  .praxis__inner[data-state='coming'] {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(40px, 6vw, 80px);
  }

  .praxis__hero {
    grid-area: hero;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 880px;
    margin-inline: auto;
  }

  .praxis__hero .praxis-coming {
    width: 100%;
    max-width: 800px;
    margin-top: clamp(0.5rem, 2vw, 1.5rem);
  }

  .praxis-coming {
    text-align: center;
  }

  .coming-title {
    margin-bottom: 20px;
    max-width: 560px;
    margin-inline: auto;
    line-height: 1.7;
  }

  .coming-body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--text-primary);
    max-width: 580px;
    margin-inline: auto;
    line-height: 1.85;
    margin-bottom: 36px;
    text-transform: none;
    letter-spacing: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Future Layout Preview (wireframe-style placeholders) */
  .praxis-preview {
    display: flex;
    flex-direction: column;
    gap: 32px;
    opacity: 0.25;
  }

  .preview-entry {
    border-left: 2px solid rgba(0, 212, 255, 0.35);
    padding: 24px 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* Top meta row: institutional identifier + date, baseline-aligned */
  .preview-meta-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* Sequential identifier — the piece's canonical name; gold sheen lives in global.css */
  .preview-num {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
  }

  /* Category eyebrow (secondary metadata) */
  .preview-tag {
    font-family: var(--font-heading);
    font-size: 0.55rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--cyan-bright);
    text-shadow: var(--cyan-glow-text);
  }

  .preview-date {
    font-family: var(--font-heading);
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    color: var(--text-muted);
  }

  .preview-title-placeholder {
    height: 16px;
    width: 70%;
    background: rgba(0, 212, 255, 0.08);
  }

  .preview-excerpt-placeholder {
    height: 10px;
    width: 100%;
    background: rgba(0, 0, 0, 0.03);
  }

  .preview-excerpt--short {
    width: 55%;
  }


  /* --- Praxis facet bar (horizontal pill row) ---
     In normal document flow as a grid row between the hero and the
     list. Chrome mirrors the About dossier card (`panel-frost-base +
     panel-dossier + panel-dossier--interactive` applied inline) so
     the filter surface reads as part of the same dossier system:
     opaque navy fill, cyan 0.22 border, chamfered clip-path, inset
     cyan highlights, outer navy shadow. The `--interactive` hover
     variant cascades when any pill is focused (:focus-within picks
     that up automatically).

     `position: relative` is required so the absolutely-positioned
     `.praxis__facets-accent` rail anchors to this element.

     Padding is intentionally tight (`14px 20px 12px`) —
     `panel-dossier` does not force its own padding, so we keep the
     compact control-bar rhythm. */
  .praxis__facets {
    grid-area: facets;
    position: relative;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 20px;
    padding: 14px 20px 12px;
  }

  /* Horizontal accent rail (flipped from the About card's vertical
     left rail). The `practice` accent gradient (cyan → cyan 0.45 →
     gold 0.55) runs left→right — Praxis literally means "practice",
     so reusing that gradient is the conceptually tightest pick from
     the About accent set. The parent's octagonal `--clip-card`
     polygon chamfers the strip at the corners for free. */
  .praxis__facets-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(
      to right,
      var(--cyan-core) 0%,
      rgba(0, 212, 255, 0.45) 40%,
      rgba(221, 184, 61, 0.55) 100%
    );
    z-index: 2;
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .praxis__facets {
      padding: 14px 16px 12px;
    }
  }

  :global(.praxis-ask) {
    grid-area: ask;
  }

  /* Panel-label eyebrow at the left edge of the bar. Visually
     anchors the control strip and serves as the accessible section
     label (the aside already carries `aria-label="Filter Praxis
     articles"`, but the visual eyebrow reinforces intent for
     sighted users). */
  .praxis__facets-heading {
    margin: 0;
    flex: 0 0 auto;
    padding-right: 16px;
    border-right: 1px solid rgba(0, 212, 255, 0.2);
    font-size: 0.6rem;
    color: var(--text-muted);
    letter-spacing: 0.25em;
  }

  /* Each facet group (LENS, TAGS) flows horizontally with its
     eyebrow label immediately preceding its pill list. Groups are
     flex-wrap so pills cascade cleanly at narrower widths. */
  .praxis__facet-group {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .praxis__facet-label {
    margin: 0;
    flex: 0 0 auto;
    font-size: 0.55rem;
    color: var(--text-muted);
    letter-spacing: 0.22em;
  }

  .praxis__facet-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Pill shape (border-radius 999px) is the intentional divergence
     from the site's otherwise sharp-cornered dossier grammar: in a
     filter bar, rounded pills signal "interactive toggle" more
     clearly than rectangles, which would read as inert dossier
     metadata chips. The frosted shell around the bar preserves the
     dossier feel at the panel level. */
  .praxis__facet-btn {
    background: transparent;
    border: 1px solid rgba(0, 212, 255, 0.25);
    border-radius: 999px;
    color: var(--text-primary);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    padding: 4px 12px;
    cursor: pointer;
    transition: background-color 120ms ease, border-color 120ms ease, color 120ms ease;
  }

  .praxis__facet-btn:hover {
    border-color: rgba(0, 212, 255, 0.6);
  }

  .praxis__facet-btn[aria-pressed='true'] {
    background: rgba(0, 212, 255, 0.18);
    border-color: rgba(0, 212, 255, 0.8);
    color: #fff;
  }

  .praxis__facet-btn:focus-visible {
    outline: 2px solid rgba(0, 212, 255, 0.75);
    outline-offset: 2px;
  }

  /* Clear action pins to the far right on wide viewports
     (margin-left: auto) so it reads as an escape hatch distinct
     from the positive filter pills. When the bar wraps at narrower
     widths, the auto margin collapses and Clear drops to the next
     line — still prominent, still tappable. */
  .praxis__facet-clear {
    margin-left: auto;
    align-self: center;
    background: transparent;
    border: 0;
    padding: 6px 0;
    color: var(--text-muted);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 120ms ease;
  }

  .praxis__facet-clear:hover,
  .praxis__facet-clear:focus-visible {
    color: #fff;
  }

  .praxis__facet-clear:focus-visible {
    outline: 2px solid rgba(0, 212, 255, 0.75);
    outline-offset: 2px;
  }

  .praxis__list {
    grid-area: list;
    display: grid;
    gap: 24px;
    /* `min(320px, 100%)` prevents the 320px min-track from exceeding
       the container width on sub-340px viewports. Without it, the
       auto-fill row is wider than the container and body{overflow-x:
       hidden} silently clips the rightmost card edge at 320px. */
    grid-template-columns: repeat(auto-fill, minmax(min(320px, 100%), 1fr));
  }

  /* Praxis card chrome borrows the ServiceCard dossier treatment:
     opaque navy fill + cyan border + octagonal chamfer come from the
     shared `.panel-dossier` utility (paint) and
     `.panel-dossier--interactive:hover` (border/shadow intensify).
     We only own padding, flex layout, and the compositional layers
     here (accent rail, mouse-follow sheen, ghost numeral watermark).
     Hover transform lift lives on the scoped :hover below — the
     shared utility does not set transform on hover, only transition
     timing, so the lift is additive not conflicting. */
  .praxis-card {
    position: relative;
    padding: 24px 32px 28px 36px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 280px;
  }

  .praxis-card:hover {
    transform: translateY(-4px);
  }

  /* --- Left accent rail (cyan gradient, matches ServiceCard default) --- */
  .praxis-card__accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(
      to bottom,
      var(--cyan-bright) 0%,
      var(--cyan-core) 55%,
      rgba(0, 212, 255, 0.25) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  /* --- Mouse-follow sheen (same recipe as .service-card__light) ---
     `--mouse-x` / `--mouse-y` are written by initPraxisCardSheen()
     below. The sheen is invisible until hover so non-interactive
     scroll is cheap (no compositor layer per card). */
  .praxis-card__light {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      400px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(0, 212, 255, 0.06),
      transparent 60%
    );
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .praxis-card:hover .praxis-card__light {
    opacity: 1;
  }

  /* --- Ghost numeral watermark (top-right, same grammar as
     `.service-card__num` so the Praxis index reads as a dossier set). */
  .praxis-card__num-watermark {
    position: absolute;
    top: 12px;
    right: 16px;
    font-family: var(--font-heading);
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1;
    color: var(--sarif-gold);
    opacity: 0.12;
    pointer-events: none;
    user-select: none;
    z-index: 1;
  }

  .praxis-card__link {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 12px;
    color: inherit;
    text-decoration: none;
    outline-offset: 4px;
  }

  .praxis-card__link:focus-visible {
    outline: 2px solid rgba(0, 212, 255, 0.75);
  }

  .praxis-card__meta-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
  }

  .praxis-card__num {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .praxis-card__date {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .praxis-card__lens {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(0, 212, 255, 0.85);
  }

  .praxis-card__title {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-size: clamp(1.25rem, 2vw, 1.6rem);
    line-height: 1.2;
    margin: 0;
    color: #fff;
  }

  .praxis-card__summary {
    color: var(--text-muted);
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .praxis-card__vt-hero {
    display: block;
    width: 100%;
    height: 2px;
    margin-top: auto;
    background: linear-gradient(90deg, rgba(0, 212, 255, 0.6), rgba(0, 212, 255, 0));
  }

  [data-praxis-card][hidden] {
    display: none;
  }

  .praxis__empty {
    grid-area: empty;
    padding: 36px 24px;
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    text-align: center;
    border: 1px dashed rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    background: rgba(10, 16, 22, 0.35);
    outline: none;
  }

  .praxis__empty:focus-visible {
    border-color: rgba(0, 212, 255, 0.45);
    box-shadow: 0 0 0 2px rgba(0, 212, 255, 0.25);
  }

  .praxis__empty-copy {
    margin: 0;
  }

  .praxis__empty-clear {
    background: none;
    border: none;
    color: var(--cyan-core);
    cursor: pointer;
    padding: 0 2px;
    text-decoration: underline dotted;
    font: inherit;
  }

  .praxis__empty-clear:hover,
  .praxis__empty-clear:focus-visible {
    color: var(--cyan-bright);
  }

  /* Round-3 P8b — View Transitions Level 2 morph handoff.
     The card's title + hero bar share a `view-transition-name` with
     the matching element on /praxis/[slug].astro, so the browser
     interpolates position/size across the document boundary.
     Gated on @supports so we never emit the declaration on engines
     that haven't shipped named view transitions (today: Firefox;
     unknown legacy Chromium-pre-111). Gated on reduced-motion-
     no-preference so motion-sensitive users still get the default
     crossfade rather than the morph (and the browser still schedules
     a transition, just without per-element animation). */
  @supports (view-transition-name: none) {
    @media (prefers-reduced-motion: no-preference) {
      .praxis-card__title {
        view-transition-name: var(--vt-title);
      }
      .praxis-card__vt-hero {
        view-transition-name: var(--vt-hero);
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .praxis-card {
      transition: none;
    }
    .praxis-card:hover {
      transform: none;
    }
    .praxis-card__light {
      display: none;
    }
  }
</style>

<script>
  /**
   * Praxis faceted filter (P9c).
   *
   * SSR renders all cards; this script hides/shows them based on
   * multi-select facet state stored in the URL query params. Popstate
   * triggers a re-sync so back/forward preserves the filter view. No-JS
   * users always see every article.
   */
  /**
   * Single AbortController for every listener wired in
   * `initPraxisFacets()` (delegation click + window popstate). Aborted
   * on `astro:before-swap` so the window-level popstate handler does
   * not survive a ClientRouter navigation to stack on the next visit.
   * The same controller also detaches the delegated click, even though
   * its root is part of the swapped-out DOM — aborting is cheaper than
   * waiting for GC and leaves no footguns.
   */
  /** @type {AbortController | null} */
  let praxisFacetsController = null;

  function initPraxisFacets() {
    const facetsRoot = document.querySelector('[data-praxis-facets]');
    if (!(facetsRoot instanceof HTMLElement)) return;
    /* P9c — click delegation on `.praxis__inner`: facet buttons, list, empty state. */
    const inner = facetsRoot.closest('.praxis__inner');
    const delegationRoot = inner instanceof HTMLElement ? inner : facetsRoot;
    if (delegationRoot.dataset.facetsWired === 'true') return;
    delegationRoot.dataset.facetsWired = 'true';

    /* Abort any prior controller from a previous page render before
       wiring new listeners. Guarded by `data-facets-wired` above, but
       belt-and-suspenders since the controller lives on window. */
    praxisFacetsController?.abort();
    praxisFacetsController = new AbortController();
    const { signal } = praxisFacetsController;

    const list = document.querySelector('[data-praxis-list]');
    if (!(list instanceof HTMLElement)) return;
    const cards = Array.from(list.querySelectorAll('[data-praxis-card]'));
    const emptyEl = document.querySelector('[data-praxis-empty]');

    const FACET_KEYS = ['lens', 'tags'];

    function readState() {
      const params = new URLSearchParams(location.search);
      const state = {};
      for (const key of FACET_KEYS) {
        const raw = params.get(key);
        state[key] = raw ? new Set(raw.split('|').filter(Boolean)) : new Set();
      }
      return state;
    }

    function writeState(state, push) {
      const params = new URLSearchParams(location.search);
      for (const key of FACET_KEYS) {
        const values = [...state[key]];
        if (values.length === 0) params.delete(key);
        else params.set(key, values.join('|'));
      }
      const next = params.toString();
      const url = next ? `${location.pathname}?${next}` : location.pathname;
      if (push) history.pushState(null, '', url);
      else history.replaceState(null, '', url);
    }

    function applyState(state) {
      let visibleCount = 0;
      const previouslyFocused = document.activeElement;
      let focusedCardWillHide = false;
      for (const card of cards) {
        const el = card;
        if (!(el instanceof HTMLElement)) continue;
        const cardTags = (el.dataset.tags || '').split('|').filter(Boolean);
        const matches = FACET_KEYS.every((key) => {
          const selected = state[key];
          if (!selected || selected.size === 0) return true;
          if (key === 'tags') return cardTags.some((t) => selected.has(t));
          const value = el.dataset[key];
          return value ? selected.has(value) : false;
        });
        el.hidden = !matches;
        if (matches) {
          visibleCount += 1;
        } else if (
          previouslyFocused instanceof Node &&
          el.contains(previouslyFocused)
        ) {
          focusedCardWillHide = true;
        }
      }
      /* Sync aria-pressed on facet buttons; require data-facet-value so we
         do not match group wrappers (data-facet-group only). */
      const buttons = delegationRoot.querySelectorAll('[data-facet][data-facet-value]');
      buttons.forEach((btn) => {
        if (!(btn instanceof HTMLButtonElement)) return;
        const key = btn.dataset.facet;
        const val = btn.dataset.facetValue;
        if (!key || !val || !state[key]) return;
        btn.setAttribute('aria-pressed', state[key].has(val) ? 'true' : 'false');
      });
      const isEmpty = visibleCount === 0;
      if (emptyEl instanceof HTMLElement && list instanceof HTMLElement) {
        emptyEl.hidden = !isEmpty;
        list.hidden = isEmpty;
      }
      /* If the facet change hid the card that currently owns focus, move
         focus to a sensible anchor so keyboard users are not stranded on
         a hidden node. Priority:
           1. Empty-state container (announced via role=status).
           2. First still-visible card link.
           3. Facets aside heading (safe fallback).
      */
      if (focusedCardWillHide) {
        if (isEmpty && emptyEl instanceof HTMLElement) {
          emptyEl.focus({ preventScroll: true });
        } else {
          const firstVisibleLink = list.querySelector(
            '[data-praxis-card]:not([hidden]) a.praxis-card__link',
          );
          if (firstVisibleLink instanceof HTMLElement) {
            firstVisibleLink.focus({ preventScroll: true });
          }
        }
      }
    }

    let state = readState();
    applyState(state);

    delegationRoot.addEventListener(
      'click',
      (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const facetBtn = target.closest('[data-facet][data-facet-value]');
        const clearBtn = target.closest('[data-facet-clear]');
        if (facetBtn instanceof HTMLButtonElement) {
          const key = facetBtn.dataset.facet;
          const val = facetBtn.dataset.facetValue;
          if (!key || !val) return;
          if (!state[key]) state[key] = new Set();
          if (state[key].has(val)) state[key].delete(val);
          else state[key].add(val);
          writeState(state, true);
          applyState(state);
        } else if (clearBtn instanceof HTMLButtonElement) {
          state = { lens: new Set(), tags: new Set() };
          writeState(state, true);
          applyState(state);
        }
      },
      { signal },
    );

    window.addEventListener(
      'popstate',
      () => {
        state = readState();
        applyState(state);
      },
      { signal },
    );
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPraxisFacets, { once: true });
  } else {
    initPraxisFacets();
  }
  document.addEventListener('astro:page-load', initPraxisFacets);
  /* Detach every facet listener before Astro swaps the DOM so the
     window-level popstate handler does not persist across navigations
     and double-fire on the next visit to /praxis/. */
  document.addEventListener('astro:before-swap', () => {
    praxisFacetsController?.abort();
    praxisFacetsController = null;
  });

  /* Mouse-follow sheen — mirrors ServiceCard's initCardSheen contract.
   * Writes `--mouse-x` / `--mouse-y` on each card so `.praxis-card__light`
   * can paint a radial gradient under the pointer. Skipped when the user
   * prefers reduced motion; idempotent via data-sheen-bound. */
  function initPraxisCardSheen() {
    const cards = document.querySelectorAll('.praxis-card');
    for (const cardRaw of cards) {
      if (!(cardRaw instanceof HTMLElement)) continue;
      if (cardRaw.hasAttribute('data-sheen-bound')) continue;
      cardRaw.setAttribute('data-sheen-bound', 'true');
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) continue;
      cardRaw.addEventListener('mousemove', (evt) => {
        if (!(evt instanceof MouseEvent)) return;
        const rect = cardRaw.getBoundingClientRect();
        const x = (evt.clientX - rect.left) / rect.width;
        const y = (evt.clientY - rect.top) / rect.height;
        cardRaw.style.setProperty('--mouse-x', (x * 100) + '%');
        cardRaw.style.setProperty('--mouse-y', (y * 100) + '%');
      }, { passive: true });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPraxisCardSheen, { once: true });
  } else {
    initPraxisCardSheen();
  }
  document.addEventListener('astro:page-load', initPraxisCardSheen);
</script>
