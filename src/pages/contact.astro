---
import Base from '../layouts/Base.astro';

// Signal-first intake (Contact Transmission Rebuild, Phase A, scope B).
// The public surface deliberately does not reference Jensen. Every field
// serves the single goal of letting a prospect state the actual signal
// and giving Nicholas a clean readout to respond to.
//
// P7b — Cloudflare Turnstile (invisible). The site key is a PUBLIC_* env
// so it's safe to emit into markup. When unset (local dev, preview
// without Access to the Turnstile app), we degrade gracefully: the
// honeypot + server-side rate limit remain in force, and the server
// skips verification. Fail-closed in the opposite direction — if the
// secret is present server-side but the key is missing client-side —
// is surfaced via the structured error shape (`verification_missing`).
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';

/** Intake line copy — signal panel TX ref (channel-status pill). */
const intakeChannelOpen = 'Channel open';
const intakeChannelBrand = 'Sarif connected';
---

<Base
  title="Contact — Sarif Consulting"
  description="Open a transmission with Sarif. Every inbound signal is read by the principal and answered with a reply — the first artifact of a Briefing or deeper engagement."
>
  <!-- Page Header -->
  <section class="contact-hero section" aria-labelledby="contact-heading">
    <div class="container contact-hero-inner">
      <p class="section-label reveal-on-scroll">Augment Your Intelligence</p>
      <h1 id="contact-heading" class="section-header connector-line reveal-on-scroll">Establish Contact</h1>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="contact-form-section section" aria-label="Contact form">
    <div class="container">
      <div class="contact-grid">
        <!-- Form -->
        <form
          id="contact-form"
          class="contact-form"
          action="/api/transmit"
          method="POST"
          novalidate
        >
          <!-- Honeypot — hidden from humans, catches bots -->
          <div class="form-group" style="position:absolute;left:-9999px;opacity:0;height:0;overflow:hidden;" aria-hidden="true">
            <label for="contact-website">Website</label>
            <input type="text" id="contact-website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          {turnstileSiteKey && (
            /* Turnstile mount (explicit render, not auto-scan).
               Class is `turnstile-mount`, NOT `cf-turnstile` — we do not
               want api.js's auto-scanner to claim the node, because:
                 1. Auto-scan only fires once per api.js load. On Astro
                    ClientRouter soft-nav back to /contact/, a fresh
                    mount node appears in the DOM but api.js is already
                    loaded and never re-scans. The widget would never
                    initialize, no token ever lands, and the submit
                    would 400 with `verification_missing`.
                 2. Explicit render returns a widget ID that we keep
                    around for `turnstile.reset(id)` after the server
                    consumes a token (tokens are single-use). Without
                    the ID, retry flows can't recover without a page
                    reload. Observed in field-reports on mobile Chrome
                    141 / Android throttled (see contact-form 400 RCA
                    in docs/audit-2026-04-phase-b.md).
               The data-* attributes below are read by ensureTurnstileRendered
               so the widget config stays declarative (easier to audit). */
            <div
              class="turnstile-mount"
              data-sitekey={turnstileSiteKey}
              data-appearance="interaction-only"
              data-response-field-name="cf-turnstile-response"
              data-theme="dark"
              data-retry="auto"
              aria-label="Security challenge"
            ></div>
          )}

          <!-- Signal panel: the operator console. Dark-glass inset against
               the light page gives the signal textarea unmistakable visual
               hierarchy without implying an AI chatbot is on the other end.
               Header shows a format-only TX preview and a live HUD counter;
               placeholder opens with an operator-prompt glyph. -->
          <div class="signal-panel-group">
            <div class="signal-panel">
              <div class="signal-panel__header" aria-hidden="true">
                <span class="signal-panel__ref">
                  <span class="signal-panel__ref-prefix">TX-</span><span class="signal-panel__ref-date">YYYY-MM</span><span class="signal-panel__ref-sep">·</span>
                  <!-- Channel-status pill (shared styles below). -->
                  <span class="channel-status channel-status--signal" aria-hidden="true">
                    <span class="channel-status__dot" aria-hidden="true"></span>
                    <span class="channel-status__text">
                      <span class="channel-status__item">{intakeChannelOpen}</span>
                      <span class="channel-status__sep" aria-hidden="true">·</span>
                      <span class="channel-status__item channel-status__item--brand">{intakeChannelBrand}</span>
                    </span>
                  </span>
                </span>
                <span class="signal-panel__hud">
                  <span id="signal-chars" class="signal-panel__hud-count">0</span><span class="signal-panel__hud-sep">/</span><span class="signal-panel__hud-max">10,000</span>
                  <!-- Minimum-length badge: the server rejects any signal
                       shorter than 20 chars with a 400. We surface that
                       threshold here rather than letting a failed submit
                       round-trip the rule. State classes:
                         signal-panel__hud-min--need    → len < 20 (cyan)
                         signal-panel__hud-min--met     → len ≥ 20 (dim)
                       Driven by initSignalCounter on every input event. -->
                  <span id="signal-min-badge" class="signal-panel__hud-min signal-panel__hud-min--need" aria-hidden="true">
                    <span class="signal-panel__hud-min-dot" aria-hidden="true"></span>
                    <span class="signal-panel__hud-min-text">20 min</span>
                  </span>
                </span>
              </div>
              <label for="contact-signal" class="signal-panel__label ui-eyebrow">Contact us</label>
              <textarea
                id="contact-signal"
                name="signal"
                rows="8"
                required
                minlength="20"
                maxlength="10000"
                class="signal-panel__input"
                placeholder="▸ What are you facing? Enough context for a clean read — at least 20 characters."
                aria-describedby="consent-line signal-hud-live signal-min-hint"
              ></textarea>
              <!-- Min-length error surface. Empty in the resting state —
                   the HUD badge ("20 min" / "3 more" / "min met") carries
                   the live signal so we don't double-narrate the rule.
                   The pre-submit guard populates this element with a
                   specific "${n} more character(s) needed…" message when
                   the user tries to transmit under the floor; cleared on
                   next valid input. -->
              <p id="signal-min-hint" class="signal-panel__min-hint" aria-live="polite"></p>
              <div id="signal-hud-live" class="visually-hidden" aria-live="polite"></div>
            </div>
          </div>

          <div class="form-group">
            <label for="contact-name" class="form-label ui-eyebrow">Name</label>
            <input
              type="text"
              id="contact-name"
              name="name"
              required
              autocomplete="name"
              class="form-input"
            />
          </div>

          <div class="form-group">
            <label for="contact-email" class="form-label ui-eyebrow">Email</label>
            <input
              type="email"
              id="contact-email"
              name="email"
              required
              autocomplete="email"
              class="form-input"
            />
          </div>

          <div class="form-group">
            <label for="contact-org" class="form-label ui-eyebrow">Organization <span class="form-optional">(optional)</span></label>
            <input
              type="text"
              id="contact-org"
              name="organization"
              autocomplete="organization"
              class="form-input"
            />
          </div>

          <div class="form-submit-wrap">
            <button
              type="submit"
              class="btn-gold cyan-gold-label form-submit form-submit--digitize"
              id="submit-btn"
              aria-label="Transmit signal"
            >
              <span class="form-submit__label sarif-hover-sheen" aria-hidden="true">Transmit</span>
            </button>

            {turnstileSiteKey && (
              /* Turnstile prelock hint.
                 Shown while the invisible Turnstile widget is still
                 resolving the challenge (usually 1–3s on desktop,
                 3–6s on throttled mobile). During this window the
                 submit button is disabled; without this hint the
                 user sees a dim button and no explanation, which
                 historically led to `verification_missing` 400s
                 because users pressed submit before the token was
                 ready (and the interaction-only widget is literally
                 invisible).

                 Initially visible (no `hidden` attr). The client
                 script hides it the moment the token lands. If the
                 script fails to load at all (CSP, extension),
                 keeping the hint visible is better than a silent
                 disabled button — the user still has the mailto
                 fallback below the form. */
              <div id="tx-prelock" class="tx-prelock" role="status" aria-live="polite">
                <span class="tx-prelock__dot" aria-hidden="true"></span>
                <span class="tx-prelock__text">Verifying connection…</span>
              </div>
            )}

            <!-- Sequencer: macro-feedback during the submit fetch. The button's
                 digitize is the micro-press; this is the phase ticker. Phases
                 are mutually exclusive via data-active on the container. Live
                 region is polite so it doesn't interrupt screen readers. -->
            <div
              id="tx-sequencer"
              class="tx-sequencer"
              role="status"
              aria-live="polite"
              aria-atomic="true"
              hidden
            >
              <span class="tx-sequencer__rail" aria-hidden="true"></span>
              <span class="tx-sequencer__phase" data-phase="encoding">
                <span class="tx-sequencer__dot" aria-hidden="true"></span>
                <span class="tx-sequencer__label">Encoding signal</span>
              </span>
              <span class="tx-sequencer__phase" data-phase="relaying">
                <span class="tx-sequencer__dot" aria-hidden="true"></span>
                <span class="tx-sequencer__label">Relaying to principal</span>
              </span>
              <span class="tx-sequencer__phase" data-phase="acknowledged">
                <span class="tx-sequencer__dot" aria-hidden="true"></span>
                <span class="tx-sequencer__label">Transmission received</span>
              </span>
              <span class="tx-sequencer__phase" data-phase="failed">
                <span class="tx-sequencer__dot" aria-hidden="true"></span>
                <span class="tx-sequencer__label">Relay failed · signal preserved</span>
              </span>
            </div>
          </div>

          <!-- Success receipt: the input surface is an operator console, and
               the response renders as a transmission receipt whose chrome
               deliberately mirrors the signal-panel header — dark glass,
               TX reference prefix, channel-status pill, monospace HUD — so
               the page never flips into an unrelated design language after
               submit. Two bubbles carry the thread: the prospect's signal
               (outgoing, operator-console styling) and Sarif's receipt
               confirmation (reply, gold-accented dark glass). The chat
               metaphor appears ONLY after submit, so prospects are never
               misled into thinking a live AI is on the other end. -->
          <div id="form-success" class="tx-receipt" role="status" aria-live="polite" hidden tabindex="-1">
            <div class="tx-receipt__header">
              <span class="tx-receipt__ref">
                <span class="tx-receipt__ref-prefix">TX-</span><span class="tx-receipt__ref-date" id="tx-receipt-ref-date">YYYY-MM</span><span class="tx-receipt__ref-sep">·</span>
                <!-- Channel-status pill mirrors the one in the signal-panel
                     header, with a state-change variant (`--delivered`) that
                     shifts the dot/accent from cyan to gold to signal
                     transmission success semantically, not just chromatically. -->
                <span class="channel-status channel-status--receipt channel-status--delivered" aria-hidden="true">
                  <span class="channel-status__dot" aria-hidden="true"></span>
                  <span class="channel-status__text">
                    <span class="channel-status__item">Signal delivered</span>
                    <span class="channel-status__sep" aria-hidden="true">·</span>
                    <span class="channel-status__item channel-status__item--brand">Sarif acknowledged</span>
                  </span>
                </span>
              </span>
              <span class="tx-receipt__timestamp" id="tx-receipt-timestamp" aria-hidden="true"></span>
            </div>
            <div class="tx-receipt__thread">
              <div class="tx-bubble tx-bubble--outgoing">
                <span class="tx-bubble__meta" aria-hidden="true">You · transmitted</span>
                <p class="tx-bubble__body" id="tx-receipt-signal"></p>
              </div>
              <div class="tx-bubble tx-bubble--reply">
                <span class="tx-bubble__meta" aria-hidden="true">Sarif · received</span>
                <p class="tx-bubble__body">
                  Your signal is in front of the principal. A reply will arrive at <span class="tx-bubble__email" id="form-success-email">your email</span>.
                </p>
              </div>
            </div>
          </div>

          <!-- Error receipt: same visual family as the success receipt (dark
               glass + TX-ref header + channel-status pill) so the page
               never flips between two unrelated design languages on
               failure. The pill carries the static "relay failed / signal
               preserved" reassurance; the dynamic server-error summary
               gets its own prominent line below the header so long error
               copy doesn't break the pill's tight typography. -->
          <div id="form-error" class="tx-receipt tx-receipt--error" role="alert" aria-live="assertive" hidden tabindex="-1">
            <div class="tx-receipt__header">
              <span class="tx-receipt__ref tx-receipt__ref--error">
                <span class="tx-receipt__ref-prefix">TX-</span><span class="tx-receipt__ref-date" data-tx-ref-date>YYYY-MM</span><span class="tx-receipt__ref-sep">·</span>
                <span class="channel-status channel-status--receipt channel-status--error" aria-hidden="true">
                  <span class="channel-status__dot" aria-hidden="true"></span>
                  <span class="channel-status__text">
                    <span class="channel-status__item">Relay failed</span>
                    <span class="channel-status__sep" aria-hidden="true">·</span>
                    <span class="channel-status__item channel-status__item--brand">Signal preserved</span>
                  </span>
                </span>
              </span>
            </div>
            <p class="tx-receipt__error-summary" id="form-error-summary"></p>
            <div class="form-fallback-actions">
              <button type="button" class="form-fallback-btn form-fallback-btn--primary" id="form-retry">
                Try again
              </button>
              <button type="button" class="form-fallback-btn" id="copy-contact-email">
                Copy info@sarifconsulting.ai
              </button>
              <a class="form-fallback-btn form-fallback-btn--link" id="mailto-fallback" href="mailto:info@sarifconsulting.ai">
                Open email app
              </a>
            </div>
            <p id="form-copy-status" class="form-copy-status" role="status" aria-live="polite"></p>
          </div>
        </form>

        <!-- Contact Info Sidebar -->
        <aside class="contact-info reveal-on-scroll" aria-label="Contact information">
          <div class="info-block">
            <h2 class="info-label ui-eyebrow">Direct</h2>
            <a
              href="mailto:info@sarifconsulting.ai"
              class="info-value info-value--link ui-eyebrow ui-eyebrow--natural-case"
            >
              info@sarifconsulting.ai
            </a>
          </div>

          <div class="info-block">
            <h2 class="info-label ui-eyebrow">Location</h2>
            <p class="info-value">Portland, Oregon</p>
          </div>

          <div class="info-divider" aria-hidden="true"></div>

          <p class="info-note">
            All communications are treated as confidential. Project details are never shared or referenced publicly without explicit authorization.
          </p>

          <!-- Passive-disclosure consent; aria-describedby on the signal textarea points here. -->
          <p id="consent-line" class="info-note">
            Your transmission is stored for 90 days unless we engage, encrypted at rest, and never used to train external models. See <a href="/privacy#retention">Privacy</a>.
          </p>
        </aside>
      </div>
    </div>
  </section>

  {turnstileSiteKey && (
    /* Turnstile script: explicit-render + onload callback.
       - `render=explicit` disables api.js's auto-scan of `.cf-turnstile`
         nodes. We render the widget ourselves via `turnstile.render()`
         so ClientRouter soft-navs can re-initialize on re-entry and
         we retain the widget ID for `turnstile.reset()` after the
         server consumes a token.
       - `onload=sarifTurnstileOnload` gives us a deterministic signal
         when api.js is ready, independent of script load-event timing
         (which is unreliable under bfcache + speculation-rules prerender).
       The callback is defined in the module script below and no-ops if
       called more than once (idempotent). */
    <script
      is:inline
      async
      defer
      src="https://challenges.cloudflare.com/turnstile/v0/api.js?onload=sarifTurnstileOnload&render=explicit"
    ></script>
  )}
</Base>

<style>
  .contact-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .contact-form-section {
    padding-top: 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 80px;
    max-width: 960px;
    margin-inline: auto;
    align-items: start;
  }

  /* Form — no reveal-on-scroll here; the form must never be hidden behind a
     transition that would make a returning tab feel unresponsive. Per plan:
     "Reduced-motion: no reveal transitions on the form." We generalize that
     to "no reveal transitions on the form at any motion preference." */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-label {
    display: block;
  }

  .form-optional {
    color: var(--text-muted);
    opacity: 0.5;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0.05em;
  }

  /* Envelope inputs (name / email / organization) inherit the operator-console
     treatment: dark glass surface, monospaced text, cyan caret. Signal panel
     still dominates via mass + chrome header, not via contrast. */
  .form-input,
  .form-textarea {
    background: linear-gradient(
      180deg,
      rgba(8, 22, 34, 0.94) 0%,
      rgba(6, 18, 28, 0.96) 100%
    );
    backdrop-filter: blur(14px) saturate(1.2);
    -webkit-backdrop-filter: blur(14px) saturate(1.2);
    border: 1px solid rgba(0, 212, 255, 0.22);
    clip-path: var(--clip-button);
    padding: 14px 20px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.88rem;
    color: rgba(240, 248, 255, 0.94);
    caret-color: var(--cyan-core);
    letter-spacing: 0.01em;
    outline: none;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
    width: 100%;
    box-shadow:
      inset 0 1px 0 rgba(0, 212, 255, 0.08),
      0 8px 20px rgba(6, 18, 28, 0.18),
      0 2px 6px rgba(0, 0, 0, 0.08);
  }

  .form-input:focus,
  .form-textarea:focus {
    border-color: rgba(0, 212, 255, 0.55);
    box-shadow:
      inset 0 1px 0 rgba(0, 212, 255, 0.18),
      0 0 0 1px rgba(221, 184, 61, 0.18),
      0 10px 26px rgba(6, 18, 28, 0.28),
      0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: rgba(0, 212, 255, 0.38);
    opacity: 1;
  }

  /* Defeat Chrome/Safari autofill yellow — it clashes with the dark surface.
     The long transition pins the inset background swap so the dark fill holds. */
  .form-input:-webkit-autofill,
  .form-input:-webkit-autofill:hover,
  .form-input:-webkit-autofill:focus,
  .form-textarea:-webkit-autofill {
    -webkit-text-fill-color: rgba(240, 248, 255, 0.94);
    -webkit-box-shadow: 0 0 0 1000px rgba(8, 22, 34, 0.96) inset;
    caret-color: var(--cyan-core);
    transition: background-color 5000s ease-in-out 0s;
  }

  .form-textarea {
    resize: vertical;
    min-height: 140px;
    line-height: 1.6;
  }

  /* ────────────────────────────────────────────────────────────────────
     Channel status — below the hero intro. Operator-channel cue: dot +
     two discrete labels (Channel open · Sarif connected).
     Dot pulses cyan under full motion; static under reduced-motion.
     Deliberately small and restrained so it reads as status, not banner.
     ──────────────────────────────────────────────────────────────────── */
  .channel-status {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 20px;
    padding: 6px 14px;
    background: rgba(0, 212, 255, 0.04);
    border: 1px solid rgba(0, 212, 255, 0.16);
    clip-path: var(--clip-sm);
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .channel-status__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--cyan-core);
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.55);
    flex-shrink: 0;
    animation: channel-pulse 2.4s ease-in-out infinite;
  }

  .channel-status__item {
    color: var(--text-primary);
  }

  /* Brand item ("Sarif connected") carries the same always-on gold sheen used by
     the sidebar info-labels (see global.css .contact-info .info-label.ui-eyebrow).
     Re-declared locally rather than reusing .ui-eyebrow because that token's
     gold gradient is gated behind `.contact-info` ancestor scope. Shares the
     same CSS variables + keyframe name, so motion/theme tuning stays
     centralized. */
  .channel-status__item--brand {
    color: transparent;
    background-image: var(--sarif-sheen-text-gradient-gold);
    background-size: 200% 100%;
    background-position: 0% 50%;
    background-repeat: no-repeat;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: none;
    filter: var(--sarif-sheen-filter-gold-text);
    animation: sarif-gold-sheen-loop var(--sarif-sheen-leg) linear infinite reverse;
  }

  .channel-status__sep {
    color: var(--text-muted);
    opacity: 0.6;
    margin: 0 4px;
  }

  /* Hero pill embedded in TX header: identical chrome; ink for dark glass. */
  .signal-panel__header .channel-status {
    margin-top: 0;
    flex-shrink: 0;
    align-self: center;
    font-family: var(--font-heading);
  }

  .signal-panel__header .channel-status.channel-status--signal {
    color: rgba(0, 212, 255, 0.5);
  }

  .signal-panel__header .channel-status .channel-status__item:not(.channel-status__item--brand) {
    color: rgba(240, 248, 255, 0.92);
  }

  .signal-panel__header .channel-status .channel-status__sep {
    color: rgba(0, 212, 255, 0.42);
    opacity: 0.85;
    margin: 0 4px;
  }

  @keyframes channel-pulse {
    0%, 100% {
      opacity: 1;
      box-shadow: 0 0 8px rgba(0, 212, 255, 0.55);
    }
    50% {
      opacity: 0.45;
      box-shadow: 0 0 4px rgba(0, 212, 255, 0.25);
    }
  }

  @media (max-width: 480px) {
    .channel-status {
      font-size: 0.58rem;
      padding: 5px 10px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .signal-panel__header .channel-status {
      max-width: 100%;
    }
  }

  /* ────────────────────────────────────────────────────────────────────
     Signal panel — dark-glass operator console against the page's light
     theme. Maximum visual hierarchy: monospace, cyan caret, ref/HUD row
     in the header, single subtle gold hairline on focus. This is where
     the page earns its on-brand, bleeding-edge feel.
     ──────────────────────────────────────────────────────────────────── */
  .signal-panel-group {
    display: flex;
    flex-direction: column;
  }

  .signal-panel {
    position: relative;
    background:
      linear-gradient(180deg, rgba(8, 22, 34, 0.97) 0%, rgba(6, 18, 28, 0.98) 100%);
    border: 1px solid rgba(0, 212, 255, 0.28);
    clip-path: var(--clip-card);
    padding: 18px 22px 22px;
    box-shadow:
      inset 0 1px 0 rgba(0, 212, 255, 0.12),
      inset 0 0 0 1px rgba(0, 212, 255, 0.04),
      0 16px 40px rgba(6, 18, 28, 0.22),
      0 4px 16px rgba(0, 0, 0, 0.12);
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .signal-panel:focus-within {
    border-color: rgba(0, 212, 255, 0.55);
    box-shadow:
      inset 0 1px 0 rgba(0, 212, 255, 0.2),
      inset 0 0 0 1px rgba(221, 184, 61, 0.12),
      0 20px 52px rgba(6, 18, 28, 0.3),
      0 4px 16px rgba(0, 0, 0, 0.14),
      0 0 0 1px rgba(221, 184, 61, 0.18);
  }

  .signal-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    /* flex-wrap lets the TX-ref / channel-status cluster drop onto a
       second row before colliding with the HUD counter on phone widths
       (≤414px). row-gap re-establishes vertical rhythm once wrapped. */
    flex-wrap: wrap;
    gap: 12px;
    row-gap: 8px;
    padding-bottom: 14px;
    margin-bottom: 14px;
    border-bottom: 1px solid rgba(0, 212, 255, 0.12);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(0, 212, 255, 0.72);
    user-select: none;
  }

  .signal-panel__ref {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    /* Allow this flex child to shrink below its intrinsic content
       width so the channel-status pill inside it can wrap on narrow
       screens instead of pushing the sibling HUD off the row. */
    min-width: 0;
    color: rgba(0, 212, 255, 0.62);
  }

  .signal-panel__ref-prefix,
  .signal-panel__ref-date {
    display: inline-block;
  }

  .signal-panel__ref-sep {
    color: rgba(255, 255, 255, 0.2);
    margin: 0 8px;
  }

  .signal-panel__hud {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-variant-numeric: tabular-nums;
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.2s ease;
  }

  .signal-panel__hud-sep {
    color: rgba(255, 255, 255, 0.22);
    margin: 0 2px;
  }

  .signal-panel__hud-count--warn {
    color: rgba(221, 184, 61, 0.92);
  }

  .signal-panel__hud-count--danger {
    color: #ff9070;
  }

  /* Min-length badge — lives next to the count. Two visual modes:
     "need" (user has not yet met the 20-char floor) pulses cyan to draw
     the eye; "met" fades to a muted check-like dim state so the HUD
     doesn't keep shouting after the bar's been cleared. The dot doubles
     as a state indicator; the text stays stable for screen-zoom users. */
  .signal-panel__hud-min {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-left: 8px;
    padding: 2px 6px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: color 0.2s ease, background-color 0.2s ease, opacity 0.2s ease;
  }
  .signal-panel__hud-min-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    display: inline-block;
    transition: background-color 0.2s ease, box-shadow 0.2s ease;
  }
  .signal-panel__hud-min--need {
    color: rgba(0, 212, 255, 0.85);
    background: rgba(0, 212, 255, 0.08);
  }
  .signal-panel__hud-min--need .signal-panel__hud-min-dot {
    background: var(--cyan-core);
    box-shadow: 0 0 6px rgba(0, 212, 255, 0.6);
    animation: signalMinPulse 1.6s ease-in-out infinite;
  }
  .signal-panel__hud-min--met {
    color: rgba(255, 255, 255, 0.32);
    background: transparent;
  }
  .signal-panel__hud-min--met .signal-panel__hud-min-dot {
    background: rgba(255, 255, 255, 0.32);
    box-shadow: none;
    animation: none;
  }
  @keyframes signalMinPulse {
    0%, 100% { opacity: 0.55; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.35); }
  }
  @media (prefers-reduced-motion: reduce) {
    .signal-panel__hud-min--need .signal-panel__hud-min-dot {
      animation: none;
      opacity: 0.85;
    }
  }

  /* Min-length hint surface. Intentionally zero-height in the resting
     state — the HUD badge carries the live "20 min / N more / min met"
     signal, so a second visible line below the textarea would be
     redundant. Populated on pre-submit rejection; cleared on valid
     input. `:empty` collapses the vertical margin so the layout
     doesn't jump when the message appears/disappears. */
  .signal-panel__min-hint {
    margin: 10px 0 0;
    padding: 0 2px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.38);
    transition: color 0.2s ease;
  }
  .signal-panel__min-hint:empty {
    margin: 0;
  }
  .signal-panel__min-hint--active {
    color: rgba(0, 212, 255, 0.78);
  }
  .signal-panel__min-hint--error {
    color: #ff9070;
  }

  .signal-panel__label {
    display: block;
    margin-bottom: 10px;
    color: rgba(0, 212, 255, 0.72);
  }

  .signal-panel__input {
    width: 100%;
    min-height: 200px;
    background: transparent;
    border: none;
    outline: none;
    padding: 0;
    resize: vertical;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.92rem;
    line-height: 1.75;
    color: rgba(240, 248, 255, 0.96);
    caret-color: var(--cyan-core);
    letter-spacing: 0.01em;
  }

  .signal-panel__input::placeholder {
    color: rgba(0, 212, 255, 0.42);
    font-style: normal;
  }

  /* Scrollbar styling inside the panel stays dark so it doesn't break
     the terminal aesthetic when the textarea overflows. */
  .signal-panel__input::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }
  .signal-panel__input::-webkit-scrollbar-track {
    background: transparent;
  }
  .signal-panel__input::-webkit-scrollbar-thumb {
    background: rgba(0, 212, 255, 0.18);
    border-radius: 999px;
  }
  .signal-panel__input::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 212, 255, 0.3);
  }

  @media (max-width: 480px) {
    .signal-panel {
      padding: 14px 16px 18px;
    }
    .signal-panel__header {
      font-size: 0.6rem;
      padding-bottom: 10px;
      margin-bottom: 10px;
    }
    .signal-panel__input {
      min-height: 220px;
      font-size: 0.9rem;
    }
  }

  /* Small-phone tier (≤380px). The "TX- YYYY-MM · CHANNEL OPEN · SARIF
     CONNECTED" string with the HUD counter is already wrapped to two
     rows by the base `flex-wrap: wrap`; at this width we further tighten
     type, drop the mid-pill "·" separator (keeps CHANNEL OPEN / SARIF
     CONNECTED readable without wrapping inside the chip), and shrink
     the TX-ref trailing separator so both rows fit the panel cleanly. */
  @media (max-width: 380px) {
    .signal-panel__header {
      font-size: 0.55rem;
      letter-spacing: 0.04em;
    }
    .signal-panel__ref-sep {
      margin: 0 4px;
    }
    .signal-panel__header .channel-status {
      padding: 4px 8px;
      gap: 6px;
      letter-spacing: 0.08em;
    }
    .signal-panel__header .channel-status .channel-status__sep {
      display: none;
    }
    /* Separate the two status items with whitespace now that the "·"
       is gone; keeps them on one line inside the pill. */
    .signal-panel__header .channel-status .channel-status__item--brand {
      margin-left: 4px;
    }
  }

  /* Visually hidden utility (local; avoids global.css churn). */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Submit — sizing + label rhythm: global.css (.form-submit, .lane-cta, .form-submit__label) */
  .form-submit-wrap {
    padding-top: 8px;
  }

  /* Turnstile prelock hint — shown while the invisible challenge is still
     resolving. Sits below the submit button, above the sequencer. Uses
     the same monospaced eyebrow system as the rest of the form so it
     reads as operator status, not a modal error. */
  .tx-prelock[hidden] {
    display: none !important;
  }
  .tx-prelock {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 10px;
    padding: 6px 10px;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(0, 212, 255, 0.78);
    background: linear-gradient(
      90deg,
      rgba(0, 212, 255, 0.06) 0%,
      rgba(0, 212, 255, 0.02) 100%
    );
    border-left: 1px solid rgba(0, 212, 255, 0.35);
  }
  .tx-prelock__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cyan-core);
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.55);
    /* GPU-composited pulse; no layout/paint thrash. */
    animation: txPrelockPulse 1.4s ease-in-out infinite;
    will-change: transform, opacity;
  }
  @keyframes txPrelockPulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.35); }
  }
  @media (prefers-reduced-motion: reduce) {
    .tx-prelock__dot {
      animation: none;
      opacity: 0.8;
    }
  }
  /* Disabled submit button (gate-locked state). `:disabled` covers both
     our `turnstileToken`-absent lock and `submitDigitize.setBusy(true)`.
     Visual intent: clearly non-interactive without looking broken —
     muted cyan bracket still suggests "will be ready soon". */
  #submit-btn:disabled,
  #submit-btn[aria-disabled='true'] {
    opacity: 0.55;
    cursor: progress;
    filter: saturate(0.7);
  }

  .form-submit__label--scrambling {
    letter-spacing: 0.18em;
    text-shadow:
      0 0 10px rgba(0, 212, 255, 0.35),
      0 0 22px rgba(0, 212, 255, 0.12);
  }

  /* ────────────────────────────────────────────────────────────────────
     TX Sequencer — macro-feedback during submit. Four mutually-exclusive
     phases toggled via [data-active] on the container. Dot scales +
     glows on the active phase; label colour shifts accordingly. Rail is
     a thin cyan line under the phases for operator-console feel.
     ──────────────────────────────────────────────────────────────────── */
  /* Explicit [hidden] guards: our .tx-sequencer / .tx-receipt rules set
     display: flex / block which would otherwise override the browser's
     user-agent [hidden] { display: none } and leak the elements visually
     when they should be off-screen. Keep these rules near the top of
     each component block so specificity always wins. */
  .tx-sequencer[hidden],
  .tx-receipt[hidden] {
    display: none !important;
  }

  .tx-sequencer {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 22px;
    margin-top: 18px;
    padding: 10px 14px;
    background: rgba(8, 22, 34, 0.04);
    border: 1px solid rgba(0, 212, 255, 0.12);
    clip-path: var(--clip-sm);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tx-sequencer__rail {
    position: absolute;
    inset: auto 14px 6px 14px;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(0, 212, 255, 0) 0%,
      rgba(0, 212, 255, 0.28) 50%,
      rgba(0, 212, 255, 0) 100%
    );
    pointer-events: none;
  }

  .tx-sequencer__phase {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(0, 212, 255, 0.38);
    transition: color 0.3s ease;
  }

  .tx-sequencer__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(0, 212, 255, 0.35);
    box-shadow: none;
    flex-shrink: 0;
    transition: background-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  /* Active-phase highlight */
  .tx-sequencer[data-active="encoding"] .tx-sequencer__phase[data-phase="encoding"],
  .tx-sequencer[data-active="relaying"] .tx-sequencer__phase[data-phase="relaying"],
  .tx-sequencer[data-active="acknowledged"] .tx-sequencer__phase[data-phase="acknowledged"] {
    color: var(--cyan-core);
  }

  .tx-sequencer[data-active="encoding"] .tx-sequencer__phase[data-phase="encoding"] .tx-sequencer__dot,
  .tx-sequencer[data-active="relaying"] .tx-sequencer__phase[data-phase="relaying"] .tx-sequencer__dot,
  .tx-sequencer[data-active="acknowledged"] .tx-sequencer__phase[data-phase="acknowledged"] .tx-sequencer__dot {
    background: var(--cyan-core);
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.7);
    transform: scale(1.35);
  }

  /* In-flight sheen: the currently-active processing phase's label carries
     the cyan text-clip sheen to signal "system working". Scoped to the two
     in-flight phases only — the acknowledged / failed terminals hold
     static color since movement would contradict a settled outcome. */
  .tx-sequencer[data-active="encoding"] .tx-sequencer__phase[data-phase="encoding"] .tx-sequencer__label,
  .tx-sequencer[data-active="relaying"] .tx-sequencer__phase[data-phase="relaying"] .tx-sequencer__label {
    display: inline-block;
    color: transparent;
    background-image: var(--sarif-sheen-text-gradient-cyan);
    background-size: 200% 100%;
    background-position: 0% 50%;
    background-repeat: no-repeat;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: none;
    filter: var(--sarif-sheen-filter-cyan-text);
    will-change: background-position;  /* transient; only set while tx-sequencer is mid-submit */
    animation: sarif-gold-sheen-loop var(--sarif-sheen-leg) linear infinite reverse;
  }

  /* Passed phases (lower-index completed) — subdued but lit, not dim */
  .tx-sequencer[data-active="relaying"] .tx-sequencer__phase[data-phase="encoding"],
  .tx-sequencer[data-active="acknowledged"] .tx-sequencer__phase[data-phase="encoding"],
  .tx-sequencer[data-active="acknowledged"] .tx-sequencer__phase[data-phase="relaying"] {
    color: rgba(0, 212, 255, 0.6);
  }

  .tx-sequencer[data-active="relaying"] .tx-sequencer__phase[data-phase="encoding"] .tx-sequencer__dot,
  .tx-sequencer[data-active="acknowledged"] .tx-sequencer__phase[data-phase="encoding"] .tx-sequencer__dot,
  .tx-sequencer[data-active="acknowledged"] .tx-sequencer__phase[data-phase="relaying"] .tx-sequencer__dot {
    background: rgba(0, 212, 255, 0.55);
  }

  /* Failure state — phase "failed" suppresses the other three. */
  .tx-sequencer__phase[data-phase="failed"] { display: none; }
  .tx-sequencer[data-active="failed"] .tx-sequencer__phase:not([data-phase="failed"]) { display: none; }
  .tx-sequencer[data-active="failed"] .tx-sequencer__phase[data-phase="failed"] {
    display: inline-flex;
    color: #cc4a1f;
  }
  .tx-sequencer[data-active="failed"] .tx-sequencer__phase[data-phase="failed"] .tx-sequencer__dot {
    background: #cc4a1f;
    box-shadow: 0 0 10px rgba(204, 74, 31, 0.55);
    transform: scale(1.35);
  }
  .tx-sequencer[data-active="failed"] .tx-sequencer__rail {
    background: linear-gradient(
      90deg,
      rgba(204, 74, 31, 0) 0%,
      rgba(204, 74, 31, 0.3) 50%,
      rgba(204, 74, 31, 0) 100%
    );
  }

  /* ────────────────────────────────────────────────────────────────────
     TX Receipt — success (and error) surface after submit. Shares visual
     DNA with `.signal-panel`: same dark glass base, cyan-accented
     TX-ref header, monospace HUD, clip-path chamfer. The page's compose
     surface and receipt surface read as one continuous operator
     console so the brand language never flips between states. Chat-
     bubble metaphor appears ONLY after submit, never while composing,
     so the prospect is never misled into thinking a live AI is on the
     other end.
     ──────────────────────────────────────────────────────────────────── */
  .tx-receipt {
    position: relative;
    padding: 18px 22px 22px;
    background:
      linear-gradient(180deg, rgba(8, 22, 34, 0.97) 0%, rgba(6, 18, 28, 0.98) 100%);
    border: 1px solid rgba(0, 212, 255, 0.28);
    clip-path: var(--clip-card);
    color: rgba(240, 248, 255, 0.94);
    box-shadow:
      inset 0 1px 0 rgba(0, 212, 255, 0.12),
      inset 0 0 0 1px rgba(0, 212, 255, 0.04),
      0 16px 40px rgba(6, 18, 28, 0.22),
      0 4px 16px rgba(0, 0, 0, 0.12);
  }

  .tx-receipt:focus {
    outline: none;
  }

  .tx-receipt:focus-visible {
    outline: 2px solid var(--cyan-core);
    outline-offset: 4px;
  }

  /* Error state: preserves the dark glass base so the visual family is
     identical; shifts the border + inner-sheen + drop-shadow warmth to
     signal failure without re-skinning the component. */
  .tx-receipt--error {
    border-color: rgba(204, 74, 31, 0.42);
    box-shadow:
      inset 0 1px 0 rgba(255, 140, 100, 0.14),
      inset 0 0 0 1px rgba(204, 74, 31, 0.06),
      0 16px 40px rgba(6, 18, 28, 0.22),
      0 4px 16px rgba(204, 74, 31, 0.12);
  }

  /* Receipt header — identical monospace eyebrow rhythm as
     `.signal-panel__header` so the two surfaces feel like the same
     console in different phases (compose / delivered / failed). */
  .tx-receipt__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    row-gap: 8px;
    padding-bottom: 14px;
    margin-bottom: 16px;
    border-bottom: 1px solid rgba(0, 212, 255, 0.12);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(0, 212, 255, 0.72);
    user-select: none;
  }

  .tx-receipt--error .tx-receipt__header {
    border-bottom-color: rgba(204, 74, 31, 0.22);
    color: rgba(255, 160, 130, 0.78);
  }

  /* TX reference cluster — matches `.signal-panel__ref` exactly, with a
     min-width:0 child so the channel-status pill inside can wrap on
     narrow viewports instead of pushing the sibling timestamp off the
     row. */
  .tx-receipt__ref {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    min-width: 0;
    color: rgba(0, 212, 255, 0.62);
  }

  .tx-receipt__ref--error {
    color: rgba(255, 160, 130, 0.62);
  }

  .tx-receipt__ref-prefix,
  .tx-receipt__ref-date {
    display: inline-block;
  }

  .tx-receipt__ref-sep {
    color: rgba(255, 255, 255, 0.2);
    margin: 0 8px;
  }

  .tx-receipt__ref--error .tx-receipt__ref-sep {
    color: rgba(255, 160, 130, 0.28);
  }

  /* Channel-status pill embedded in a receipt header. Reuses the
     shared `.channel-status` component (see section above) and tweaks
     the typography + chrome to sit comfortably on the dark glass
     surface, mirroring `.signal-panel__header .channel-status`. */
  .tx-receipt__header .channel-status {
    margin-top: 0;
    flex-shrink: 0;
    align-self: center;
    font-family: var(--font-heading);
  }

  .tx-receipt__header .channel-status.channel-status--delivered {
    color: rgba(221, 184, 61, 0.6);
    border-color: rgba(221, 184, 61, 0.28);
    background: rgba(221, 184, 61, 0.05);
  }

  .tx-receipt__header .channel-status.channel-status--error {
    color: rgba(255, 160, 130, 0.58);
    border-color: rgba(204, 74, 31, 0.32);
    background: rgba(204, 74, 31, 0.06);
  }

  .tx-receipt__header .channel-status .channel-status__item:not(.channel-status__item--brand) {
    color: rgba(240, 248, 255, 0.92);
  }

  .tx-receipt__header .channel-status.channel-status--delivered .channel-status__dot {
    background: var(--gold-bright, #ddb83d);
    box-shadow: 0 0 8px rgba(221, 184, 61, 0.55);
  }

  .tx-receipt__header .channel-status.channel-status--error .channel-status__dot {
    background: #cc4a1f;
    box-shadow: 0 0 8px rgba(204, 74, 31, 0.55);
    /* Failure is a terminal state — pulsing would read as "retrying". */
    animation: none;
  }

  .tx-receipt__header .channel-status .channel-status__sep {
    color: rgba(0, 212, 255, 0.42);
    opacity: 0.85;
    margin: 0 4px;
  }

  .tx-receipt--error .tx-receipt__header .channel-status .channel-status__sep {
    color: rgba(255, 160, 130, 0.42);
  }

  /* Timestamp — monospace, low-contrast, pinned to the end of the row
     via `margin-left:auto`. On narrow viewports we allow it to fall to
     its own row (see 540px breakpoint below). */
  .tx-receipt__timestamp {
    margin-left: auto;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.42);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* Error summary line: dedicated surface for the dynamic server-error
     copy written by JS. Sits below the header so long messages have
     breathing room without breaking the pill's tight typography. */
  .tx-receipt__error-summary {
    margin: 0 0 14px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.55;
    color: rgba(255, 198, 178, 0.92);
    overflow-wrap: anywhere;
    min-height: 0;
  }

  .tx-receipt__error-summary:empty {
    display: none;
  }

  .tx-receipt__thread {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .tx-bubble {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: 88%;
    padding: 12px 16px;
    clip-path: var(--clip-sm);
  }

  /* Outgoing bubble: operator-console inset on the dark glass. Cyan
     border + inner sheen match the textarea's focused state so the
     prospect's transmitted signal reads as a direct quote of what
     they typed. */
  .tx-bubble--outgoing {
    align-self: flex-end;
    background:
      linear-gradient(180deg, rgba(6, 18, 28, 0.88) 0%, rgba(4, 14, 22, 0.92) 100%);
    border: 1px solid rgba(0, 212, 255, 0.38);
    color: rgba(240, 248, 255, 0.96);
    box-shadow:
      inset 0 1px 0 rgba(0, 212, 255, 0.14),
      0 4px 14px rgba(0, 0, 0, 0.28);
  }

  /* Reply bubble: same dark glass family, warmed with gold so Sarif's
     voice visually asserts itself as the acknowledging party. A single
     gold hairline (top inset) echoes the focus-within signature of the
     signal-panel on submit. */
  .tx-bubble--reply {
    align-self: flex-start;
    background:
      linear-gradient(180deg, rgba(16, 30, 44, 0.92) 0%, rgba(10, 22, 34, 0.95) 100%);
    border: 1px solid rgba(221, 184, 61, 0.42);
    color: rgba(248, 236, 196, 0.94);
    box-shadow:
      inset 0 1px 0 rgba(221, 184, 61, 0.2),
      0 4px 14px rgba(0, 0, 0, 0.22),
      0 0 0 1px rgba(221, 184, 61, 0.08);
  }

  .tx-bubble__meta {
    font-family: var(--font-heading);
    font-size: 0.58rem;
    font-weight: 600;
