</style>

<script>
  import {
    installFormDraft,
    clearFormDraft,
    queueFailedSubmission,
  } from '../scripts/form-draft.js';

  const PUBLIC_CONTACT_EMAIL = 'info@sarifconsulting.ai';
  const CONTACT_DRAFT_KEY = 'sarif:contact-draft';
  const CONTACT_DRAFT_FIELDS = ['name', 'organization', 'signal'];
  const CONTACT_IDEMPOTENCY_KEY_STORAGE = 'sarif:contact-idem-key';
  const SUBMIT_MIN_HOLD_MS = 1200;

  /* ──────────────────────────────────────────────────────────────────────
   * Turnstile lifecycle
   * ──────────────────────────────────────────────────────────────────────
   * The contact page renders a Cloudflare Turnstile widget in
   * interaction-only mode. That widget issues a short-lived token which
   * must accompany the /api/transmit POST body as `cf-turnstile-response`.
   * The server rejects submissions without a token (400, code
   * `verification_missing`), which used to surface on any submission that
   * landed before the challenge auto-resolved — especially on throttled
   * mobile.
   *
   * We do three things to make this reliably green:
   *   1. Explicit render. We don't rely on the `cf-turnstile` auto-scan
   *      because it only fires once per api.js load. Astro ClientRouter
   *      soft-navs back to /contact/ insert a fresh mount node that the
   *      already-loaded api.js never re-scans.
   *   2. Submit gate. The submit button stays `disabled` until the
   *      widget's `callback` fires with a token. A visible "Verifying
   *      connection…" hint explains the brief lock (the widget itself
   *      is invisible in interaction-only mode).
   *   3. Post-submit reset. Tokens are single-use. After every server
   *      response (success OR failure) we `turnstile.reset(widgetId)`
   *      so the next submission has a fresh token. On 400
   *      verification_missing / challenge_failed we reset + re-lock
   *      the gate so the retry button works without a page reload.
   */
  const TURNSTILE_MOUNT_SELECTOR = '.turnstile-mount[data-sitekey]';
  /** Opaque widget ID returned by `turnstile.render()`. Null until rendered. */
  /** @type {string | null} */
  let turnstileWidgetId = null;
  /** Latest issued token. Empty string = no token / consumed / expired. */
  let turnstileToken = '';
  /** True while a /api/transmit fetch is in flight. */
  let turnstileSubmitting = false;
  /** Cached reference to the mount element so reset callbacks can find the form. */
  /** @type {HTMLElement | null} */
  let turnstileMountEl = null;

  /**
   * Typed accessor for the Turnstile global. api.js defines
   * `window.turnstile` at runtime, but the DOM typings don't know about
   * it. We read it from a centralized helper so every call site stays
   * readable and the single ts-expect-error below documents the runtime
   * contract once. Returning the global as `any` is intentional: Turnstile's
   * widget config shape is large and version-drifts; a narrower local
   * definition would rot and produce false-positive type errors.
   * @returns {any}
   */
  function getTurnstileGlobal() {
    // @ts-expect-error — window.turnstile is defined at runtime by
    // https://challenges.cloudflare.com/turnstile/v0/api.js. The
    // DOM lib has no ambient type for it and we don't want to inflict
    // a global .d.ts on the rest of the project for a page-scoped
    // dependency.
    return window.turnstile;
  }

  function turnstileReady() {
    // Narrow guard: api.js defines window.turnstile with `.render()` and
    // `.reset()` once it has loaded and initialized. Checking both guards
    // against a partially-defined global (seen briefly during load).
    if (typeof window === 'undefined') return false;
    const ts = getTurnstileGlobal();
    return (
      !!ts &&
      typeof ts.render === 'function' &&
      typeof ts.reset === 'function'
    );
  }

  /** True iff the page has a Turnstile mount node (feature-detect, not env-detect). */
  function hasTurnstileMount() {
    return document.querySelector(TURNSTILE_MOUNT_SELECTOR) instanceof HTMLElement;
  }

  /**
   * Inject / update the hidden `cf-turnstile-response` input that rides
   * along the form's JSON payload. Called whenever the token changes so
   * `FormData(form)` serialization picks up the latest value without
   * requiring the submit handler to know where the token lives.
   */
  function updateTurnstileHiddenInput() {
    const form = document.getElementById('contact-form');
    if (!(form instanceof HTMLFormElement)) return;
    const name =
      turnstileMountEl?.dataset?.responseFieldName || 'cf-turnstile-response';
    const existing = form.querySelector(`input[type="hidden"][name="${name}"]`);
    /** @type {HTMLInputElement} */
    let input;
    if (existing instanceof HTMLInputElement) {
      input = existing;
    } else {
      input = document.createElement('input');
      input.type = 'hidden';
      input.name = name;
      form.appendChild(input);
    }
    input.value = turnstileToken;
  }

  /**
   * Reconcile the submit button + prelock hint with the current gate
   * state. Idempotent; safe to call from any state change (token arrive,
   * token expire, submit start, submit end).
   *
   * Precedence: `turnstileSubmitting` always wins (button disabled, hint
   * hidden — the sequencer takes over). Otherwise the gate is driven by
   * token presence when Turnstile is on the page at all.
   */
  function refreshSubmitGate() {
    const submitBtn = document.getElementById('submit-btn');
    const prelockEl = document.getElementById('tx-prelock');
    const turnstileOnPage = hasTurnstileMount();
    const gateLocked = turnstileOnPage && !turnstileToken;

    if (submitBtn instanceof HTMLButtonElement) {
      // Only we touch `disabled` for the gate. `submitDigitize.setBusy()`
      // also manages disabled during submit — that's fine, both agree
      // on "disabled during submit". The finally-block below calls
      // `refreshSubmitGate()` AFTER `setBusy(false)` so the final state
      // is correct regardless of token presence.
      submitBtn.disabled = gateLocked || turnstileSubmitting;
      if (gateLocked && !turnstileSubmitting) {
        submitBtn.setAttribute('aria-disabled', 'true');
      } else {
        submitBtn.removeAttribute('aria-disabled');
      }
    }
    if (prelockEl instanceof HTMLElement) {
      const showHint = gateLocked && !turnstileSubmitting;
      if (showHint) {
        prelockEl.removeAttribute('hidden');
      } else {
        prelockEl.setAttribute('hidden', '');
      }
    }
  }

  function setTurnstileToken(token) {
    turnstileToken = typeof token === 'string' ? token : '';
    updateTurnstileHiddenInput();
    refreshSubmitGate();
  }

  function clearTurnstileToken() {
    turnstileToken = '';
    updateTurnstileHiddenInput();
    refreshSubmitGate();
  }

  /**
   * Explicitly render the Turnstile widget. Idempotent — the mount node
   * carries a `data-turnstile-rendered` sentinel so repeat calls (e.g.
   * from `astro:page-load` firing on the same DOM) are no-ops.
   */
  function ensureTurnstileRendered() {
    const mountNode = document.querySelector(TURNSTILE_MOUNT_SELECTOR);
    if (!(mountNode instanceof HTMLElement)) return;
    const mount = mountNode;
    if (mount.dataset.turnstileRendered === 'true') {
      turnstileMountEl = mount;
      return;
    }
    if (!turnstileReady()) {
      // api.js hasn't finished loading yet. Our `sarifTurnstileOnload`
      // callback (below) will drive us back here once it has.
      turnstileMountEl = mount;
      return;
    }

    try {
      const ts = getTurnstileGlobal();
      const widgetId = ts.render(mount, {
        sitekey: mount.dataset.sitekey,
        appearance: mount.dataset.appearance || 'always',
        theme: mount.dataset.theme || 'auto',
        retry: mount.dataset.retry || 'auto',
        'response-field-name':
          mount.dataset.responseFieldName || 'cf-turnstile-response',
        callback: (/** @type {string} */ token) => {
          setTurnstileToken(token);
        },
        'error-callback': () => {
          // Widget errored out (network, expired challenge page, etc.).
          // Keep the gate locked. `retry: auto` above asks Turnstile to
          // re-issue; when it succeeds the `callback` fires again.
          clearTurnstileToken();
        },
        'expired-callback': () => {
          // Token aged out before submission. Clear + reset so a fresh
          // challenge is issued automatically.
          clearTurnstileToken();
          try {
            if (turnstileWidgetId !== null) ts.reset(turnstileWidgetId);
          } catch {
            // swallow — reset is best-effort
          }
        },
        'timeout-callback': () => {
          // Used by Turnstile when `retry` is disabled; we're on `auto`
          // so this path is rare. Fall through to expired semantics.
          clearTurnstileToken();
        },
      });
      turnstileWidgetId = widgetId;
      turnstileMountEl = mount;
      mount.dataset.turnstileRendered = 'true';
    } catch (err) {
      // Render failure is non-fatal: leave the gate locked, the user
      // still has the mailto fallback. Log for operator visibility.
      const message =
        err instanceof Error ? err.message : String(err);
      console.warn('turnstile_render_failed', { message });
    }
  }

  /**
   * Reset the Turnstile widget after a server response consumes (or
   * rejects) the token. Called unconditionally in the submit handler's
   * finally block. The gate re-locks until the widget reissues.
   */
  function resetTurnstileAfterServerResponse() {
    if (!hasTurnstileMount()) return;
    turnstileToken = '';
    updateTurnstileHiddenInput();
    try {
      if (turnstileReady() && turnstileWidgetId !== null) {
        getTurnstileGlobal().reset(turnstileWidgetId);
      }
    } catch {
      // Best-effort. If reset fails, the next `callback` will still fire
      // when the widget self-heals, and refreshSubmitGate reconciles.
    }
    refreshSubmitGate();
  }

  // Expose the api.js onload hook. api.js is loaded with
  // ?onload=sarifTurnstileOnload and will call this exactly once,
  // after which `window.turnstile` is guaranteed ready. Attached
  // directly on window so it's reachable by the api.js `?onload=`
  // param; the ts-expect-error documents the runtime-only binding
  // (see getTurnstileGlobal above for the same pattern).
  if (typeof window !== 'undefined') {
    // @ts-expect-error — runtime-only global, see getTurnstileGlobal.
    window.sarifTurnstileOnload = function () {
      ensureTurnstileRendered();
    };
  }

  function ensureContactIdempotencyKey() {
    try {
      let key = sessionStorage.getItem(CONTACT_IDEMPOTENCY_KEY_STORAGE);
      if (!key) {
        key =
          typeof crypto !== 'undefined' && typeof crypto.randomUUID === 'function'
            ? crypto.randomUUID()
            : `ck-${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
        sessionStorage.setItem(CONTACT_IDEMPOTENCY_KEY_STORAGE, key);
      }
      return key;
    } catch {
      return `ck-${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
    }
  }

  function rotateContactIdempotencyKey() {
    try {
      sessionStorage.removeItem(CONTACT_IDEMPOTENCY_KEY_STORAGE);
    } catch {
      // Noop
    }
  }

  const SUBMIT_LABEL_IDLE = 'Transmit';
  const SUBMIT_LABEL_ACTIVE = 'Augment';
  const SUBMIT_LABEL_BUSY = 'Transmitting...';
  const SCRAMBLE_CHARSET = '0123456789ABCDEF';
  const SCRAMBLE_FRAME_COUNT = 14;

  /**
   * @param {HTMLButtonElement} button
   * @param {HTMLElement} labelSpan
   */
  function initSubmitLabelDigitize(button, labelSpan) {
    const reduceMq = window.matchMedia('(prefers-reduced-motion: reduce)');
    function prefersReducedMotion() {
      return reduceMq.matches;
    }

    let busy = false;
    let pointerInside = false;
    let animGeneration = 0;
    let rafId = 0;

    function randomScrambleChar() {
      return SCRAMBLE_CHARSET[Math.floor(Math.random() * SCRAMBLE_CHARSET.length)] ?? '0';
    }

    function setScrambling(on) {
      labelSpan.classList.toggle('form-submit__label--scrambling', on);
    }

    function cancelAnimation() {
      animGeneration += 1;
      if (rafId) {
        cancelAnimationFrame(rafId);
        rafId = 0;
      }
      setScrambling(false);
    }

    function animateTo(target) {
      if (prefersReducedMotion()) {
        labelSpan.textContent = target;
        setScrambling(false);
        return;
      }

      cancelAnimation();
      const gen = animGeneration;
      let frame = 0;

      function tick() {
        if (gen !== animGeneration || busy) return;

        frame += 1;
        const progress = frame / SCRAMBLE_FRAME_COUNT;

        if (progress >= 1) {
          labelSpan.textContent = target;
          setScrambling(false);
          rafId = 0;
          return;
        }

        setScrambling(true);
        const resolved = Math.floor(progress * target.length);
        let out = '';
        for (let i = 0; i < target.length; i++) {
          const ch = target[i];
          if (ch === ' ' || ch === '.') {
            out += ch;
            continue;
          }
          out += i < resolved ? ch : randomScrambleChar();
        }
        labelSpan.textContent = out;
        rafId = requestAnimationFrame(tick);
      }

      rafId = requestAnimationFrame(tick);
    }

    function destinationLabel() {
      if (busy) return SUBMIT_LABEL_BUSY;
      if (pointerInside || document.activeElement === button) return SUBMIT_LABEL_ACTIVE;
      return SUBMIT_LABEL_IDLE;
    }

    function applyVisual() {
      if (busy) {
        cancelAnimation();
        labelSpan.textContent = SUBMIT_LABEL_BUSY;
        return;
      }
      animateTo(destinationLabel());
    }

    function setBusy(nextBusy) {
      busy = nextBusy;
      if (busy) {
        cancelAnimation();
        labelSpan.textContent = SUBMIT_LABEL_BUSY;
        button.setAttribute('disabled', 'true');
        button.setAttribute('aria-busy', 'true');
        return;
      }
      button.removeAttribute('aria-busy');
      button.removeAttribute('disabled');
      applyVisual();
    }

    button.addEventListener('mouseenter', () => {
      pointerInside = true;
      if (!busy) applyVisual();
    });

    button.addEventListener('mouseleave', () => {
      pointerInside = false;
      if (!busy) applyVisual();
    });

    button.addEventListener('focus', () => {
      if (!busy) applyVisual();
    });

    button.addEventListener('blur', () => {
      if (!busy) applyVisual();
    });

    const onMq = () => {
      if (!busy) applyVisual();
    };
    if (typeof reduceMq.addEventListener === 'function') {
      reduceMq.addEventListener('change', onMq);
    } else {
      reduceMq.addListener(onMq);
    }

    labelSpan.textContent = SUBMIT_LABEL_IDLE;
    setScrambling(false);

    return {
      setBusy,
      destroy() {
        cancelAnimation();
        if (typeof reduceMq.removeEventListener === 'function') {
          reduceMq.removeEventListener('change', onMq);
        } else {
          reduceMq.removeListener(onMq);
        }
      },
    };
  }

  function buildTransmitMailto(form) {
    const fd = new FormData(form);
    const name = String(fd.get('name') || '').trim();
    const email = String(fd.get('email') || '').trim();
    const org = String(fd.get('organization') || '').trim();
    const signal = String(fd.get('signal') || '').trim();
    const subject = `Transmission from ${name || 'Sarif site'}`.slice(0, 200);
    const body = [
      `Name: ${name}`,
      `Email: ${email}`,
      org ? `Organization: ${org}` : null,
      '',
      'Signal:',
      signal.slice(0, 6000),
    ]
      .filter(Boolean)
      .join('\n')
      .slice(0, 8000);
    return `mailto:${PUBLIC_CONTACT_EMAIL}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  }

  function setContactErrorMessage(errorSummaryEl, status, json) {
    const fallback =
      'Delivery is taking longer than expected. Copy info@sarifconsulting.ai or open your email app to reach Sarif directly.';
    // Post-P7a: server responds with { ok, code, field?, message }. We keep
    // backwards-compat with the legacy `{ error }` shape so bfcache-served
    // pages don't surface an empty toast while the service worker updates.
    const pickMessage = () => {
      if (json && typeof json.message === 'string') return json.message;
      if (json && typeof json.error === 'string') return json.error;
      return null;
    };
    const msg = pickMessage();
    /* 503 is a recoverable operator-facing failure (Turnstile down, or
       missing secret in a misconfigured prod deploy). We want the server
       copy verbatim because it already carries the retry timing and email
       fallback. Same for 400 `verification_missing` / `verification_unavailable`
       on the challenge surface. */
    if ((status === 400 || status === 429 || status === 502 || status === 503) && msg) {
      errorSummaryEl.textContent = msg;
      return;
    }
    if (status === 500) {
      errorSummaryEl.textContent = fallback;
      return;
    }
    if (msg) {
      errorSummaryEl.textContent = msg;
      return;
    }
    errorSummaryEl.textContent = fallback;
  }

  // Truncate a signal for display in the outgoing receipt bubble. We keep
  // a generous cap (~360 chars) so short transmissions render whole while
  // long ones show the lede with a clear ellipsis + archived hint.
  const RECEIPT_SIGNAL_MAX = 360;
  function truncateForReceipt(str) {
    const s = (str ?? '').trim();
    if (s.length <= RECEIPT_SIGNAL_MAX) return s;
    return s.slice(0, RECEIPT_SIGNAL_MAX).trimEnd() + '…';
  }

  // "YYYY-MM" in UTC — matches the TX reference format stamped by the
  // server. Rendering it client-side means the preview stays in sync
  // at month boundaries without a rebuild. Keeps the operator header
  // honest without leaking the real (internal) reference id.
  function currentRefDate() {
    const d = new Date();
    const yyyy = d.getUTCFullYear();
    const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
    return `${yyyy}-${mm}`;
  }

  // Format "YYYY-MM-DD HH:MM UTC" for the receipt header timestamp.
  function nowReceiptStamp() {
    const d = new Date();
    const yyyy = d.getUTCFullYear();
    const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
    const dd = String(d.getUTCDate()).padStart(2, '0');
    const hh = String(d.getUTCHours()).padStart(2, '0');
    const mi = String(d.getUTCMinutes()).padStart(2, '0');
    return `${yyyy}-${mm}-${dd} ${hh}:${mi} UTC`;
  }

  // Sequencer helper: sets data-active, optionally auto-hides after a
  // terminal phase. Returns a thin controller so the submit flow can
  // drive it without threading the element everywhere.
  function initSequencer(el) {
    if (!(el instanceof HTMLElement)) {
      return { show() {}, setPhase() {}, hide() {} };
    }
    /** @type {ReturnType<typeof setTimeout> | null} */
    let hideTimer = null;
    function clearHide() {
      if (hideTimer) {
        clearTimeout(hideTimer);
        hideTimer = null;
      }
    }
    return {
      show() {
        clearHide();
        el.removeAttribute('hidden');
      },
      setPhase(phase) {
        el.setAttribute('data-active', phase);
      },
      hide(delayMs = 0) {
        clearHide();
        if (delayMs <= 0) {
          el.setAttribute('hidden', '');
          el.removeAttribute('data-active');
          return;
        }
        hideTimer = setTimeout(() => {
          el.setAttribute('hidden', '');
          el.removeAttribute('data-active');
          hideTimer = null;
        }, delayMs);
      },
    };
  }

  // Char counter with tiered thresholds (warn at 80%, danger at 95%)
  // so prospects feel HUD-level awareness, not alarm.
  // SIGNAL_MIN mirrors functions/api/_shared/validate.js LIMITS.SIGNAL_MIN;
  // keep them in sync or the client guard lies about the server contract.
  const SIGNAL_MIN = 20;
  const SIGNAL_MAX = 10000;
  const SIGNAL_WARN_AT = 8000;
  const SIGNAL_DANGER_AT = 9500;
  // Resting copy for the min-length hint line. The hint is empty by
  // default — the HUD badge carries the live "20 min" signal — and is
  // only populated when the pre-submit guard rejects an under-floor
  // submit. Restoring to '' after the user corrects the field hides
  // the line again cleanly.
  const SIGNAL_MIN_HINT_DEFAULT = '';
  function initSignalCounter(textarea, countEl, liveEl) {
    if (!(textarea instanceof HTMLTextAreaElement) || !(countEl instanceof HTMLElement)) {
      return;
    }
    const fmt = new Intl.NumberFormat('en-US');
    const minBadgeEl = document.getElementById('signal-min-badge');
    const minBadgeTextEl = minBadgeEl?.querySelector('.signal-panel__hud-min-text');
    const minHintEl = document.getElementById('signal-min-hint');
    // Debounce the aria-live announcement so rapid typing doesn't flood
    // screen readers. We only announce on thresholds crossings.
    /** @type {'empty' | 'under-min' | 'ok' | 'warn' | 'danger'} */
    let lastState = 'empty';
    function classifyState(len) {
      if (len === 0) return 'empty';
      if (len < SIGNAL_MIN) return 'under-min';
      if (len >= SIGNAL_DANGER_AT) return 'danger';
      if (len >= SIGNAL_WARN_AT) return 'warn';
      return 'ok';
    }
    function update() {
      const len = textarea.value.length;
      countEl.textContent = fmt.format(len);
      countEl.classList.toggle('signal-panel__hud-count--warn', len >= SIGNAL_WARN_AT && len < SIGNAL_DANGER_AT);
      countEl.classList.toggle('signal-panel__hud-count--danger', len >= SIGNAL_DANGER_AT);

      // Min-length badge. "need" when we're under the floor (prompt to
      // keep going), "met" once cleared (visually recedes without
      // disappearing — keeps the minimum discoverable to a user who
      // happens to delete back under later).
      if (minBadgeEl instanceof HTMLElement) {
        const needsMore = len < SIGNAL_MIN;
        minBadgeEl.classList.toggle('signal-panel__hud-min--need', needsMore);
        minBadgeEl.classList.toggle('signal-panel__hud-min--met', !needsMore);
        if (minBadgeTextEl instanceof HTMLElement) {
          if (needsMore) {
            const remaining = SIGNAL_MIN - len;
            // "20 min" when empty; "12 more" while typing under the floor;
            // "min met" once cleared. Stable lengths so the HUD width
            // doesn't jitter as the user types.
            if (len === 0) {
              minBadgeTextEl.textContent = `${SIGNAL_MIN} min`;
            } else {
              minBadgeTextEl.textContent = `${remaining} more`;
            }
          } else {
            minBadgeTextEl.textContent = 'min met';
          }
        }
      }

      // Visible helper line under the textarea — warms up to cyan when
      // the user is actively typing but hasn't met the floor yet. Once
      // the floor is cleared, drop the post-submit `--error` state too
      // so the hint returns to its neutral resting copy.
      if (minHintEl instanceof HTMLElement) {
        minHintEl.classList.toggle(
          'signal-panel__min-hint--active',
          len > 0 && len < SIGNAL_MIN,
        );
        if (len >= SIGNAL_MIN && minHintEl.classList.contains('signal-panel__min-hint--error')) {
          minHintEl.classList.remove('signal-panel__min-hint--error');
          minHintEl.textContent = SIGNAL_MIN_HINT_DEFAULT;
          textarea.removeAttribute('aria-invalid');
        }
      }

      const state = classifyState(len);
      if (state !== lastState && liveEl instanceof HTMLElement) {
        if (state === 'under-min') {
          // Only announce once per typing pass, when the user is clearly
          // entering content but still below threshold. Not on every
          // keystroke — that would drown the screen reader.
          liveEl.textContent = `${SIGNAL_MIN - textarea.value.length} more characters needed before you can transmit.`;
        } else if (state === 'ok' && lastState === 'under-min') {
          liveEl.textContent = 'Minimum length met.';
        } else if (state === 'warn') {
          liveEl.textContent = 'Approaching maximum length.';
        } else if (state === 'danger') {
          liveEl.textContent = `${SIGNAL_MAX - len} characters remaining.`;
        } else {
          liveEl.textContent = '';
        }
        lastState = state;
      }
    }
    textarea.addEventListener('input', update);
    update();
  }

  function initContactForm() {
    const formRaw = document.getElementById('contact-form');
    /** @type {HTMLFormElement | null} */
    const form = formRaw instanceof HTMLFormElement ? formRaw : null;
    const successEl = document.getElementById('form-success');
    const successEmailEl = document.getElementById('form-success-email');
    const errorEl = document.getElementById('form-error');
    const errorSummaryEl = document.getElementById('form-error-summary');
    const copyBtn = document.getElementById('copy-contact-email');
    const mailtoEl = document.getElementById('mailto-fallback');
    const retryBtn = document.getElementById('form-retry');
    const copyStatusEl = document.getElementById('form-copy-status');
    const submitBtn = document.getElementById('submit-btn');
    const submitLabelEl = submitBtn?.querySelector('.form-submit__label');
    const signalEl = document.getElementById('contact-signal');
    const signalCountEl = document.getElementById('signal-chars');
    const signalLiveEl = document.getElementById('signal-hud-live');
    const refDateEl = document.querySelector('.signal-panel__ref-date');
    const sequencerEl = document.getElementById('tx-sequencer');
    const receiptSignalEl = document.getElementById('tx-receipt-signal');
    const receiptStampEl = document.getElementById('tx-receipt-timestamp');

    if (!form || form._bound) {
      // Second initContactForm pass on the same DOM — e.g. the user
      // navigated away and back via ClientRouter onto a cached/bfcached
      // page whose form element survived. The handlers are already
      // bound, but the Turnstile widget may still need (re-)rendering
      // because api.js's auto-scan doesn't fire on SPA nav and we now
      // use explicit render. Idempotent; no-op if already rendered.
      if (hasTurnstileMount()) {
        ensureTurnstileRendered();
        refreshSubmitGate();
      }
      return;
    }
    form._bound = true;

    if (refDateEl instanceof HTMLElement) {
      refDateEl.textContent = currentRefDate();
    }
    // Mirror the TX reference date into the success / error receipt
    // headers. Both receipts share the exact YYYY-MM string as the
    // signal-panel so the page reads as one continuous transmission
    // record across compose → deliver / fail states.
    const receiptRefDate = currentRefDate();
    const txReceiptRefDateEl = document.getElementById('tx-receipt-ref-date');
    if (txReceiptRefDateEl instanceof HTMLElement) {
      txReceiptRefDateEl.textContent = receiptRefDate;
    }
    document.querySelectorAll('[data-tx-ref-date]').forEach((el) => {
      if (el instanceof HTMLElement) {
        el.textContent = receiptRefDate;
      }
    });

    installFormDraft({
      formId: 'contact-form',
      storageKey: CONTACT_DRAFT_KEY,
      fields: CONTACT_DRAFT_FIELDS,
    });

    initSignalCounter(signalEl, signalCountEl, signalLiveEl);

    const sequencer = initSequencer(sequencerEl);

    // Turnstile bootstrap (if the mount is on the page). Lock the submit
    // gate immediately; unlock once the widget's callback fires with a
    // token. `ensureTurnstileRendered` is idempotent so calling it here
    // AND from the api.js onload hook is safe — whichever arrives first
    // wins, the other returns early.
    if (hasTurnstileMount()) {
      refreshSubmitGate();
      ensureTurnstileRendered();
    }

    /** @type {ReturnType<typeof initSubmitLabelDigitize> | null} */
    let submitDigitize =
      submitBtn && submitLabelEl instanceof HTMLElement
        ? initSubmitLabelDigitize(submitBtn, submitLabelEl)
        : null;

    retryBtn?.addEventListener('click', () => {
      errorEl?.setAttribute('hidden', '');
      if (copyStatusEl) copyStatusEl.textContent = '';
      const firstFieldRaw = form?.querySelector('input:not([type="hidden"]), textarea');
      /** @type {HTMLElement | null} */
      const firstField = firstFieldRaw instanceof HTMLElement ? firstFieldRaw : null;
      firstField?.focus({ preventScroll: false });
      firstField?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });

    copyBtn?.addEventListener('click', async () => {
      if (copyStatusEl) copyStatusEl.textContent = '';
      try {
        await navigator.clipboard.writeText(PUBLIC_CONTACT_EMAIL);
        if (copyStatusEl) copyStatusEl.textContent = 'Email address copied to clipboard.';
      } catch {
        if (copyStatusEl) copyStatusEl.textContent = 'Copy blocked — select the address in the Direct section.';
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Client-side signal-min check runs BEFORE form.checkValidity() so
      // we can show a branded, specific message in the signal hint line
      // instead of the browser's pale-yellow `minlength` tooltip. The
      // threshold mirrors the server (`functions/api/_shared/validate.js`
      // LIMITS.SIGNAL_MIN = 20); keep them in sync. We keep the native
      // `minlength="20"` on the textarea too so keyboard-only users and
      // `form.checkValidity()` still have a second line of defense (e.g.
      // if someone scripts a submit or bypasses this listener).
      const signalField = form.querySelector('#contact-signal');
      if (signalField instanceof HTMLTextAreaElement) {
        const signalLen = signalField.value.length;
        if (signalLen > 0 && signalLen < SIGNAL_MIN) {
          const minHintEl = document.getElementById('signal-min-hint');
          if (minHintEl instanceof HTMLElement) {
            const remaining = SIGNAL_MIN - signalLen;
            const noun = remaining === 1 ? 'character' : 'characters';
            minHintEl.textContent =
              `${remaining} more ${noun} needed — share enough context for a clean readout.`;
            minHintEl.classList.remove('signal-panel__min-hint--active');
            minHintEl.classList.add('signal-panel__min-hint--error');
          }
          const liveEl = document.getElementById('signal-hud-live');
          if (liveEl instanceof HTMLElement) {
            liveEl.textContent = `Signal is too short. ${SIGNAL_MIN - signalLen} more characters needed.`;
          }
          signalField.setAttribute('aria-invalid', 'true');
          signalField.focus({ preventScroll: false });
          signalField.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
        // Reset any prior under-min error state once the field is valid.
        signalField.removeAttribute('aria-invalid');
        const minHintEl = document.getElementById('signal-min-hint');
        if (minHintEl instanceof HTMLElement) {
          minHintEl.classList.remove('signal-panel__min-hint--error');
          minHintEl.textContent = SIGNAL_MIN_HINT_DEFAULT;
        }
      }

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const data = new FormData(form);
      const payload = Object.fromEntries(data.entries());

      if (payload.website) {
        if (receiptSignalEl) receiptSignalEl.textContent = '';
        if (receiptStampEl) receiptStampEl.textContent = nowReceiptStamp();
        successEl?.removeAttribute('hidden');
        form.reset();
        successEl?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        return;
      }
      delete payload.website;

      if (mailtoEl) {
        mailtoEl.setAttribute('href', buildTransmitMailto(form));
      }

      // Capture the signal text BEFORE form.reset() clears it — the
      // outgoing receipt bubble needs the original prospect text.
      const transmittedSignal = typeof payload.signal === 'string' ? payload.signal : '';

      submitDigitize?.setBusy(true);
      form.setAttribute('aria-busy', 'true');
      // Mark the gate busy so `refreshSubmitGate()` — which can be
      // invoked by a Turnstile callback firing mid-flight — doesn't
      // fight the digitize busy state. Cleared in `finally`.
      turnstileSubmitting = true;
      refreshSubmitGate();
      const submitStartedAt = Date.now();
      sequencer.show();
      sequencer.setPhase('encoding');
      // Short encoding dwell for operator feel. Honest: the fetch
      // hasn't fired yet, we really are "encoding" the request body.
      await new Promise((r) => setTimeout(r, 280));
      sequencer.setPhase('relaying');

      try {
        const res = await fetch('/api/transmit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Idempotency-Key': ensureContactIdempotencyKey(),
          },
          body: JSON.stringify(payload),
        });

        const json = await res.json().catch(() => ({}));

        const isSuccess =
          res.ok && json.ok !== false && json.success !== false;
        if (isSuccess) {
          sequencer.setPhase('acknowledged');
          if (successEmailEl) {
            const emailValue = typeof payload.email === 'string' ? payload.email.trim() : '';
            successEmailEl.textContent = emailValue || 'your email';
          }
          if (receiptSignalEl) {
            receiptSignalEl.textContent = truncateForReceipt(transmittedSignal);
          }
          if (receiptStampEl) {
            receiptStampEl.textContent = nowReceiptStamp();
          }
          // Brief acknowledged-phase dwell so the state lands visibly
          // before the receipt takes over. Reduced-motion users still
          // see the phase change; the dwell is fine either way.
          await new Promise((r) => setTimeout(r, 420));
          successEl?.removeAttribute('hidden');
          errorEl?.setAttribute('hidden', '');
          if (copyStatusEl) copyStatusEl.textContent = '';
          clearFormDraft(CONTACT_DRAFT_KEY);
          rotateContactIdempotencyKey();
          form.reset();
          successEl?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          successEl?.focus({ preventScroll: true });
          sequencer.hide(600);
        } else {
          sequencer.setPhase('failed');
          if (errorSummaryEl) setContactErrorMessage(errorSummaryEl, res.status, json);
          // Transient server faults (502, 503, 504) queue a silent retry.
          // 4xx responses mean the request itself was rejected — no point
          // retrying until the user edits and resubmits. 429 is the
          // operator's explicit back-off; we honor that by not queuing.
          if (res.status === 502 || res.status === 503 || res.status === 504) {
            queueFailedSubmission({
              endpoint: '/api/transmit',
              idempotencyKey: ensureContactIdempotencyKey(),
              payload,
            });
          }
          errorEl?.removeAttribute('hidden');
          successEl?.setAttribute('hidden', '');
          errorEl?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          errorEl?.focus({ preventScroll: true });
          sequencer.hide(800);
        }
      } catch {
        sequencer.setPhase('failed');
        if (errorSummaryEl) {
          errorSummaryEl.textContent =
            'Network error — check your connection, or use Open email app below.';
        }
        // Network abort / offline — queue for flush on `online` or next visit.
        queueFailedSubmission({
          endpoint: '/api/transmit',
          idempotencyKey: ensureContactIdempotencyKey(),
          payload,
        });
        errorEl?.removeAttribute('hidden');
        successEl?.setAttribute('hidden', '');
        errorEl?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        errorEl?.focus({ preventScroll: true });
        sequencer.hide(800);
      } finally {
        // Enforce a minimum submit-hold window so accidental double-clicks
        // on flaky networks can't slip past the disabled state. The digitize
        // label reflects the busy state visually; we just keep it locked.
        const elapsed = Date.now() - submitStartedAt;
        if (elapsed < SUBMIT_MIN_HOLD_MS) {
          await new Promise((r) => setTimeout(r, SUBMIT_MIN_HOLD_MS - elapsed));
        }
        submitDigitize?.setBusy(false);
        form.removeAttribute('aria-busy');
        // Tokens are single-use regardless of whether the server accepted
        // or rejected them. Resetting unconditionally here does three
        // things at once:
        //   1. Reclaims the gate for the next attempt on 4xx (user sees
        //      "Verifying connection…" while a fresh token is issued).
        //   2. Prevents a stale token from being replayed on a retry.
        //   3. On success the form is reset and hidden; the reset here
        //      keeps state coherent for any double-submit timing.
        turnstileSubmitting = false;
        resetTurnstileAfterServerResponse();
      }
    });
  }

  function handleContactPageShow(event) {
    if (!event.persisted) return;
    const form = document.getElementById('contact-form');
    if (form instanceof HTMLFormElement) {
      form.removeAttribute('aria-busy');
      const submit = document.getElementById('submit-btn');
      if (submit instanceof HTMLButtonElement) {
        submit.disabled = false;
      }
    }
    const sequencer = document.getElementById('tx-sequencer');
    if (sequencer instanceof HTMLElement) {
      sequencer.setAttribute('hidden', '');
      sequencer.removeAttribute('data-active');
    }
    // bfcache restore: a stale Turnstile token likely rode along in
    // memory. Clear it, reset the widget, and reconcile the gate so
    // the user starts from a clean verification state rather than
    // submitting a token that may already be consumed or expired.
    turnstileSubmitting = false;
    if (hasTurnstileMount()) {
      resetTurnstileAfterServerResponse();
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactForm, { once: true });
  } else {
    initContactForm();
  }
  document.addEventListener('astro:page-load', initContactForm);
  window.addEventListener('pageshow', handleContactPageShow);
</script>
